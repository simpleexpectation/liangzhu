{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "lib": [
      "ES2020"
    ],
    "typeRoots": [
      "./typings"
    ]
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "miniprogram_npm"
  ]
}
