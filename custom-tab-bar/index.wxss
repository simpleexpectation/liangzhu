.tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  z-index: 20;
}

.tab-bar__mask {
  position: fixed;
  inset: 0;
}

.tab-bar__mask {
  background: rgba(8, 8, 9, 0.34);
  backdrop-filter: blur(10rpx);
}

.tab-bar__fab {
  position: absolute;
  right: 8rpx;
  bottom: calc(118rpx + env(safe-area-inset-bottom));
  width: 94rpx;
  height: 94rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(243, 241, 231, 0.14);
  backdrop-filter: blur(18rpx);
  color: #f3f1e7;
  box-shadow:
    0 18rpx 40rpx rgba(0, 0, 0, 0.22),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.1);
}

.tab-bar__fab-icon {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 300;
}

.tab-bar__composer {
  position: fixed;
  left: 50%;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  width: min(620rpx, calc(100vw - 132rpx));
  min-height: 52vh;
  padding: 0;
  z-index: 21;
}

.tab-bar__composer-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.tab-bar__composer-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tab-bar__composer-title {
  display: block;
  color: #f5f1e8;
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: -0.8rpx;
  line-height: 1.14;
}

.tab-bar__composer-sub {
  color: rgba(245, 241, 232, 0.5);
  font-size: 22rpx;
  line-height: 1.6;
}

.tab-bar__composer-close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(245, 241, 232, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  line-height: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tab-bar__composer-body {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: 0;
  backdrop-filter: none;
}

.tab-bar__composer-textarea {
  width: 100%;
  height: 420rpx;
  padding: 30rpx 28rpx;
  box-sizing: border-box;
  border-radius: 44rpx;
  background:
    radial-gradient(circle at 82% 14%, rgba(246, 228, 170, 0.34), transparent 22%),
    radial-gradient(circle at 22% 84%, rgba(191, 206, 223, 0.22), transparent 26%),
    linear-gradient(180deg, rgba(181, 194, 206, 0.96), rgba(217, 196, 183, 0.96) 56%, rgba(238, 212, 150, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 38rpx 90rpx rgba(0, 0, 0, 0.32),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
  color: #171312;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.8;
  letter-spacing: 0.2rpx;
  position: relative;
  z-index: 1;
}

.tab-bar__composer-placeholder {
  color: rgba(23, 19, 18, 0.28);
}

.tab-bar__composer-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  position: relative;
  z-index: 3;
}

.tab-bar__composer-secondary,
.tab-bar__composer-primary {
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
  border: 0;
  line-height: 84rpx;
}

.tab-bar__composer-secondary {
  flex: 1;
  background: linear-gradient(180deg, rgba(255, 248, 229, 0.48), rgba(226, 207, 168, 0.34));
  color: rgba(23, 19, 18, 0.72);
  border: 0;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 10rpx 18rpx rgba(0, 0, 0, 0.08);
}

.tab-bar__composer-primary {
  flex: 1.1;
  background: linear-gradient(135deg, #f3e2b6, #e8c06d);
  color: #17130f;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.16);
}

.tab-bar__launch-sheet {
  position: fixed;
  left: 50%;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  width: min(620rpx, calc(100vw - 132rpx));
  z-index: 22;
}

.tab-bar__launch-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.tab-bar__launch-sheet-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tab-bar__launch-sheet-eyebrow {
  color: rgba(245, 241, 232, 0.36);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.tab-bar__launch-sheet-title {
  color: #f5f1e8;
  font-size: 38rpx;
  line-height: 1.14;
  font-weight: 600;
  letter-spacing: -0.8rpx;
}

.tab-bar__launch-sheet-sub {
  color: rgba(245, 241, 232, 0.5);
  font-size: 22rpx;
  line-height: 1.6;
}

.tab-bar__launch-sheet-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(245, 241, 232, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tab-bar__launch-sheet-card {
  position: relative;
  overflow: hidden;
  min-height: 52vh;
  padding: 30rpx 26rpx 24rpx;
  border-radius: 44rpx;
  background:
    radial-gradient(circle at 82% 14%, rgba(246, 228, 170, 0.34), transparent 22%),
    radial-gradient(circle at 22% 84%, rgba(191, 206, 223, 0.22), transparent 26%),
    linear-gradient(180deg, rgba(181, 194, 206, 0.96), rgba(217, 196, 183, 0.96) 56%, rgba(238, 212, 150, 0.96) 100%);
  box-shadow:
    0 38rpx 90rpx rgba(0, 0, 0, 0.32),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.tab-bar__launch-sheet-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  pointer-events: none;
}

.tab-bar__launch-sheet-glow--a {
  right: -10rpx;
  top: -6rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 249, 223, 0.18);
}

.tab-bar__launch-sheet-glow--b {
  left: 10rpx;
  bottom: 10rpx;
  width: 200rpx;
  height: 150rpx;
  background: rgba(255, 207, 168, 0.14);
}

.tab-bar__launch-sheet-grid,
.tab-bar__launch-actions {
  position: relative;
  z-index: 1;
}

.tab-bar__launch-sheet-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.tab-bar__launch-cell {
  min-height: 132rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(23, 19, 18, 0.08);
  backdrop-filter: blur(12rpx);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tab-bar__launch-cell--wide {
  grid-column: 1 / -1;
}

.tab-bar__launch-label {
  color: rgba(23, 19, 18, 0.42);
  font-size: 18rpx;
  line-height: 1.3;
}

.tab-bar__launch-value {
  color: #171312;
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 600;
}

.tab-bar__launch-input,
.tab-bar__launch-textarea {
  width: 100%;
  color: #171312;
  font-size: 26rpx;
  line-height: 1.6;
  background: transparent;
  border: 0;
  padding: 0;
  box-sizing: border-box;
}

.tab-bar__launch-textarea {
  min-height: 84rpx;
}

.tab-bar__launch-textarea--title {
  min-height: 64rpx;
  font-size: 30rpx;
  line-height: 1.34;
  font-weight: 600;
}

.tab-bar__launch-placeholder {
  color: rgba(23, 19, 18, 0.28);
}

.tab-bar__launch-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
  position: relative;
  z-index: 2;
}

.tab-bar__launch-secondary,
.tab-bar__launch-primary {
  min-height: 78rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.tab-bar__launch-secondary {
  flex: 1;
  background: linear-gradient(180deg, rgba(255, 248, 229, 0.48), rgba(226, 207, 168, 0.34));
  color: rgba(23, 19, 18, 0.74);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 10rpx 18rpx rgba(0, 0, 0, 0.08);
}

.tab-bar__launch-primary {
  flex: 1.05;
  background: linear-gradient(135deg, #f3e2b6, #e8c06d);
  color: #17130f;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.14);
}

.tab-bar__rail {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 18rpx 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(96, 59, 20, 0.18), rgba(0, 0, 0, 0)),
    #000000;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.42);
  position: relative;
  z-index: 3;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 0 14rpx;
  min-height: 88rpx;
  color: rgba(243, 241, 231, 0.42);
  position: relative;
  z-index: 4;
}

.tab-bar__item--active {
  color: #f3f1e7;
}

.tab-bar__icon {
  font-size: 28rpx;
}

.tab-bar__text {
  font-size: 20rpx;
}
