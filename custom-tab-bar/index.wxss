  border-radius: 50%;
  filter: blur(40rpx);
  pointer-events: none;
}

.tab-bar__launch-sheet-glow--a {
  right: -10rpx;
  top: -6rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 249, 223, 0.18);
}

.tab-bar__launch-sheet-glow--b {
  left: 10rpx;
  bottom: 10rpx;
  width: 200rpx;
  height: 150rpx;
  background: rgba(255, 207, 168, 0.14);
}

.tab-bar__launch-sheet-grid,
.tab-bar__launch-actions {
  position: relative;
  z-index: 1;
}

.tab-bar__launch-sheet-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.tab-bar__launch-cell {
  min-height: 132rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(23, 19, 18, 0.08);
  backdrop-filter: blur(12rpx);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tab-bar__launch-cell--wide {
  grid-column: 1 / -1;
}

.tab-bar__launch-label {
  color: rgba(23, 19, 18, 0.42);
  font-size: 18rpx;
  line-height: 1.3;
}

.tab-bar__launch-value {
  color: #171312;
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 600;
}

.tab-bar__launch-input,
.tab-bar__launch-textarea {
  width: 100%;
  color: #171312;
  font-size: 26rpx;
  line-height: 1.6;
  background: transparent;
  border: 0;
  padding: 0;
  box-sizing: border-box;
}

.tab-bar__launch-textarea {
  min-height: 84rpx;
}

.tab-bar__launch-textarea--title {
  min-height: 64rpx;
  font-size: 30rpx;
  line-height: 1.34;
  font-weight: 600;
}

.tab-bar__launch-placeholder {
  color: rgba(23, 19, 18, 0.28);
}

.tab-bar__launch-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
  position: relative;
  z-index: 2;
}

.tab-bar__launch-secondary,
.tab-bar__launch-primary {
  min-height: 78rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.tab-bar__launch-secondary {
  flex: 1;
  background: linear-gradient(180deg, rgba(255, 248, 229, 0.48), rgba(226, 207, 168, 0.34));
  color: rgba(23, 19, 18, 0.74);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 10rpx 18rpx rgba(0, 0, 0, 0.08);
}

.tab-bar__launch-primary {
  flex: 1.05;
  background: linear-gradient(135deg, #f3e2b6, #e8c06d);
  color: #17130f;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.14);
}

.tab-bar__rail {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 18rpx 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(96, 59, 20, 0.18), rgba(0, 0, 0, 0)),
    #000000;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.42);
  position: relative;
  z-index: 3;
  transition: opacity 260ms ease, transform 320ms ease;
}

.tab-bar__rail--hidden {
  opacity: 0;
  transform: translateY(34rpx) scale(0.97);
  pointer-events: none;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 0 14rpx;
  min-height: 88rpx;
  color: rgba(243, 241, 231, 0.42);
  position: relative;
  z-index: 4;
}

.tab-bar__item--active {
  color: #f3f1e7;
}

.tab-bar__icon {
  font-size: 28rpx;
}

.tab-bar__text {
  font-size: 20rpx;
}
