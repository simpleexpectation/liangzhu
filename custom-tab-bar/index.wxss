.tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  z-index: 20;
}

.tab-bar__mask {
  position: fixed;
  inset: 0;
}

.tab-bar__mask {
  background: rgba(8, 8, 9, 0.34);
  backdrop-filter: blur(10rpx);
}

.tab-bar__starfield {
  position: fixed;
  inset: 0;
  z-index: 24;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 88%, rgba(255, 231, 119, 0.14), transparent 18%),
    linear-gradient(180deg, rgba(2, 2, 4, 0.78), rgba(6, 6, 9, 0.92) 22%, rgba(8, 8, 10, 0.98));
}

.tab-bar__starfield-impact,
.tab-bar__starfield-shock {
  position: absolute;
  left: 50%;
  bottom: calc(104rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  border-radius: 50%;
  pointer-events: none;
}

.tab-bar__starfield-impact {
  width: 48rpx;
  height: 48rpx;
  background: radial-gradient(circle, rgba(255, 245, 186, 1), rgba(255, 214, 73, 0.88) 54%, rgba(255, 214, 73, 0));
  box-shadow:
    0 0 22rpx rgba(255, 234, 125, 0.74),
    0 0 80rpx rgba(255, 184, 76, 0.4);
  animation: star-impact 620ms ease forwards;
}

.tab-bar__starfield-shock {
  border: 2rpx solid rgba(255, 220, 91, 0.34);
  opacity: 0;
}

.tab-bar__starfield-shock--a {
  width: 100rpx;
  height: 100rpx;
  animation: shock-ring 900ms ease-out forwards;
}

.tab-bar__starfield-shock--b {
  width: 100rpx;
  height: 100rpx;
  animation: shock-ring 900ms ease-out 120ms forwards;
}

@keyframes star-impact {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(-180rpx) scale(0.5);
  }
  58% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  100% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1.14);
  }
}

@keyframes shock-ring {
  0% {
    opacity: 0.72;
    transform: translateX(-50%) scale(0.3);
  }
  100% {
    opacity: 0;
    transform: translateX(-50%) scale(8.2);
  }
}

.tab-bar__terrain {
  position: absolute;
  width: calc(50% - 12rpx);
  height: calc(50% - 12rpx);
  padding: 36rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff8e8;
  transition: transform 560ms cubic-bezier(0.22, 1, 0.36, 1), opacity 320ms ease, width 560ms cubic-bezier(0.22, 1, 0.36, 1), height 560ms cubic-bezier(0.22, 1, 0.36, 1), left 560ms cubic-bezier(0.22, 1, 0.36, 1), right 560ms cubic-bezier(0.22, 1, 0.36, 1), top 560ms cubic-bezier(0.22, 1, 0.36, 1), bottom 560ms cubic-bezier(0.22, 1, 0.36, 1);
  transform: translateY(100%);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow:
    0 24rpx 52rpx rgba(0, 0, 0, 0.24),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.04);
}

.tab-bar__starfield--open .tab-bar__terrain,
.tab-bar__starfield--impact .tab-bar__terrain {
  transform: translateY(0);
}

.tab-bar__terrain--tonight {
  left: 0;
  top: 0;
