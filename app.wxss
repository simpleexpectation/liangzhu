@import "styles/theme.wxss";

page {
  background: var(--bg);
  color: var(--text-primary);
  font-family: "SF Pro Display", "PingFang SC", sans-serif;
}

.page-shell {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  padding: 0 32rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #000000;
  opacity: 1;
  transform: translateY(0);
  transition: opacity 220ms ease, transform 220ms ease;
}

.page-shell::before,
.page-shell::after {
  content: "";
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.page-shell::before {
  inset: -22% -28%;
  background:
    radial-gradient(circle at 72% 18%, rgba(244, 232, 132, 0.22), transparent 23%),
    radial-gradient(circle at 22% 34%, rgba(153, 180, 210, 0.16), transparent 25%),
    radial-gradient(circle at 48% 78%, rgba(232, 169, 143, 0.16), transparent 30%);
  filter: blur(10rpx);
  opacity: 0.9;
  animation: nightGlowDrift 24s ease-in-out infinite alternate;
}

.page-shell::after {
  inset: 0;
  background-image:
    radial-gradient(rgba(255, 248, 220, 0.26) 1.2rpx, transparent 1.2rpx),
    radial-gradient(rgba(206, 226, 255, 0.16) 1rpx, transparent 1rpx);
  background-size: 156rpx 190rpx, 230rpx 270rpx;
  background-position: 24rpx 40rpx, 120rpx 180rpx;
  opacity: 0.18;
  transform: translate3d(0, 0, 0);
  animation: nightStarsDrift 36s linear infinite;
}

.page-shell > view,
.page-shell > scroll-view,
.page-shell > swiper,
.page-shell > nav-shell {
  position: relative;
  z-index: 1;
}

.glass-panel {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(28rpx);
}

.section-title {
  font-size: 64rpx;
  line-height: 0.98;
  letter-spacing: -2rpx;
  font-weight: 600;
}

.section-copy {
  margin-top: 14rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.cta-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 90rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.cta-button--light {
  background: linear-gradient(135deg, #f1eddd, #d8cfb5);
  color: #111111;
}

.cta-button--ghost {
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.03);
}

.floating-blur {
  position: absolute;
  filter: blur(26rpx);
  opacity: 0.9;
  animation: drift 7s ease-in-out infinite;
}

.page-ready {
  opacity: 1;
  transform: translateY(0);
}

.page-leaving {
  opacity: 0;
  transform: translateY(22rpx);
}

@keyframes drift {
  0%,
  100% {
    transform: translateY(0rpx) scale(1);
  }
  50% {
    transform: translateY(-10rpx) scale(1.03);
  }
}

@keyframes pulseGlow {
  0%,
  100% {
    opacity: 0.82;
  }
  50% {
    opacity: 1;
  }
}

@keyframes nightGlowDrift {
  0% {
    transform: translate3d(-36rpx, -24rpx, 0) scale(1);
    opacity: 0.72;
  }
  45% {
    transform: translate3d(44rpx, 36rpx, 0) scale(1.1);
    opacity: 0.95;
  }
  100% {
    transform: translate3d(-18rpx, 70rpx, 0) scale(1.04);
    opacity: 0.78;
  }
}

@keyframes nightStarsDrift {
  0% {
    transform: translate3d(0, 0, 0);
    opacity: 0.12;
  }
  50% {
    opacity: 0.24;
  }
  100% {
    transform: translate3d(-56rpx, 72rpx, 0);
    opacity: 0.12;
  }
}

.thought-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 260;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 46rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.58);
  backdrop-filter: blur(10rpx);
  animation: thoughtModalFadeIn 180ms ease;
}

.thought-modal__window {
  width: 100%;
  max-height: 44vh;
  min-height: 430rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #0a0b0b;
  box-shadow:
    0 28rpx 90rpx rgba(0, 0, 0, 0.46),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
  animation: thoughtModalRise 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
  transition: max-height 220ms ease, min-height 220ms ease;
}

.thought-modal__window--expanded {
  max-height: 68vh;
  min-height: 520rpx;
}

.thought-modal__scroll {
  max-height: 44vh;
}

.thought-modal__scroll--expanded {
  max-height: 68vh;
}

.thought-modal__hero {
  min-height: 192rpx;
  padding: 26rpx 30rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 18rpx;
}

.thought-modal__hero--0 {
  background:
    radial-gradient(circle at 78% 16%, rgba(245, 233, 183, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(146, 166, 178, 0.98), rgba(186, 168, 159, 0.95) 52%, rgba(216, 190, 151, 0.98) 100%);
}

.thought-modal__hero--1 {
  background:
    radial-gradient(circle at 82% 18%, rgba(244, 221, 197, 0.26), transparent 26%),
    linear-gradient(180deg, rgba(217, 198, 182, 0.98), rgba(198, 208, 188, 0.96) 58%, rgba(228, 206, 186, 0.96));
}

.thought-modal__hero--2 {
  background:
    radial-gradient(circle at 78% 16%, rgba(196, 218, 255, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(165, 182, 198, 0.98), rgba(197, 205, 218, 0.96) 52%, rgba(213, 191, 176, 0.96));
}

.thought-modal__hero--3 {
  background:
    radial-gradient(circle at 18% 84%, rgba(245, 195, 208, 0.26), transparent 26%),
    linear-gradient(180deg, rgba(214, 194, 202, 0.98), rgba(190, 177, 193, 0.96) 54%, rgba(222, 194, 182, 0.96));
}

.thought-modal__hero--4 {
  background:
    radial-gradient(circle at 82% 18%, rgba(250, 238, 210, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(210, 206, 194, 0.98), rgba(181, 188, 198, 0.96) 56%, rgba(214, 198, 176, 0.96));
}

.thought-modal__label {
  color: rgba(255, 255, 255, 0.66);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
  font-weight: 700;
}

.thought-modal__title {
  display: block;
  color: rgba(255, 255, 255, 0.96);
  font-size: 42rpx;
  line-height: 1.16;
  letter-spacing: 0;
  font-weight: 800;
  text-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.18);
}

.thought-modal__body {
  min-height: 238rpx;
  padding: 26rpx 30rpx 30rpx;
  background: #0a0b0b;
  box-sizing: border-box;
}

.thought-modal__text {
  display: block;
  color: rgba(243, 241, 231, 0.86);
  font-size: 27rpx;
  line-height: 1.72;
  font-weight: 500;
  white-space: pre-wrap;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
}

.thought-modal__text--expanded {
  overflow: visible;
  display: block;
  -webkit-line-clamp: initial;
}

.thought-modal__expand {
  width: 0;
  height: 0;
  margin: 22rpx auto 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 14rpx solid rgba(243, 241, 231, 0.58);
  opacity: 0.9;
}

@keyframes thoughtModalFadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

@keyframes thoughtModalRise {
  0% {
    opacity: 0;
    transform: translate3d(0, 18rpx, 0) scale(0.98);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}
