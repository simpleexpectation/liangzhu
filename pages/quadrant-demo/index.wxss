.quadrant-demo-page {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 82% 10%, rgba(245, 231, 141, 0.12), transparent 24%),
    radial-gradient(circle at 18% 18%, rgba(174, 202, 229, 0.1), transparent 24%),
    radial-gradient(circle at 20% 72%, rgba(236, 181, 136, 0.1), transparent 24%),
    linear-gradient(180deg, #151210 0%, #120f12 42%, #110f14 100%);
  opacity: 0;
  transform: translateY(20rpx) scale(0.985);
  transition: opacity 220ms ease, transform 220ms ease;
}

.quadrant-demo-page.page-ready {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.quadrant-demo-page__glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(96rpx);
  pointer-events: none;
  opacity: 0.7;
}

.quadrant-demo-page__glow--a {
  width: 420rpx;
  height: 340rpx;
  top: 80rpx;
  right: -40rpx;
  background: rgba(243, 224, 144, 0.14);
}

.quadrant-demo-page__glow--b {
  width: 340rpx;
  height: 300rpx;
  left: -20rpx;
  top: 720rpx;
  background: rgba(166, 199, 228, 0.12);
}

.quadrant-demo-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quadrant-demo-nav__back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 250, 242, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  color: #f3f1e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
}

.quadrant-demo-nav__copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.quadrant-demo-nav__title {
  color: #f3f1e7;
  font-size: 42rpx;
  font-weight: 600;
}

.quadrant-demo-nav__sub {
  color: rgba(243, 241, 231, 0.46);
  font-size: 22rpx;
}

.quadrant-demo-stage {
  margin-top: 28rpx;
}

.quadrant-demo {
  position: relative;
  overflow: hidden;
  height: 820rpx;
  border-radius: 40rpx;
  box-shadow: 0 30rpx 84rpx rgba(0, 0, 0, 0.24);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.quadrant-demo__panel {
  position: absolute;
  width: 50%;
  height: 50%;
  padding: 34rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #f3f1e7;
  transition: transform 560ms ease, opacity 420ms ease, width 560ms ease, height 560ms ease, left 560ms ease, top 560ms ease, right 560ms ease, bottom 560ms ease;
}

.quadrant-demo__panel--tonight {
  left: 0;
  top: 0;
  background:
    radial-gradient(circle at 78% 22%, rgba(248, 227, 151, 0.18), transparent 24%),
    linear-gradient(180deg, rgba(46, 37, 27, 0.9), rgba(23, 20, 19, 0.92));
}

.quadrant-demo__panel--liangzhu {
  right: 0;
  top: 0;
  background:
    radial-gradient(circle at 20% 18%, rgba(165, 200, 232, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(22, 34, 41, 0.9), rgba(16, 19, 24, 0.92));
}

.quadrant-demo__panel--meet {
  left: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 76% 22%, rgba(239, 181, 133, 0.18), transparent 22%),
    linear-gradient(180deg, rgba(47, 25, 22, 0.92), rgba(20, 15, 15, 0.96));
}

.quadrant-demo__panel--mine {
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 28% 22%, rgba(224, 212, 176, 0.14), transparent 22%),
    linear-gradient(180deg, rgba(30, 29, 34, 0.92), rgba(15, 15, 18, 0.98));
}

.quadrant-demo__eyebrow {
  color: rgba(243, 241, 231, 0.38);
  font-size: 18rpx;
  letter-spacing: 2.2rpx;
  text-transform: uppercase;
}

.quadrant-demo__word {
  font-size: 68rpx;
  font-weight: 600;
  letter-spacing: -2rpx;
}

.quadrant-demo__copy {
  color: rgba(243, 241, 231, 0.72);
  font-size: 22rpx;
  line-height: 1.58;
  max-width: 220rpx;
}

.quadrant-demo__center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 360rpx;
  padding: 34rpx 28rpx;
  box-sizing: border-box;
  border-radius: 36rpx;
  transform: translate(-50%, -50%);
  background: rgba(8, 8, 10, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.28);
  transition: opacity 220ms ease, transform 420ms ease;
}

.quadrant-demo__center--hidden {
  opacity: 0;
  transform: translate(-50%, -56%);
}

.quadrant-demo__center-eyebrow {
  color: rgba(243, 241, 231, 0.4);
  font-size: 18rpx;
  letter-spacing: 2.2rpx;
  text-transform: uppercase;
}

.quadrant-demo__center-title {
  display: block;
  margin-top: 12rpx;
  color: #f3f1e7;
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.15;
}

.quadrant-demo__center-copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.66);
  font-size: 22rpx;
  line-height: 1.6;
}

.quadrant-demo__panel--active {
  z-index: 3;
}

.quadrant-demo__panel--muted {
  opacity: 0.18;
  transform: scale(0.96);
}

.quadrant-demo--focused-tonight .quadrant-demo__panel--active,
.quadrant-demo--focused-liangzhu .quadrant-demo__panel--active,
.quadrant-demo--focused-meet .quadrant-demo__panel--active,
.quadrant-demo--focused-mine .quadrant-demo__panel--active {
  width: 100%;
  height: 100%;
  left: 0;
  right: auto;
  top: 0;
  bottom: auto;
}

.quadrant-demo-caption {
  margin-top: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.quadrant-demo-caption__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.38);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.quadrant-demo-caption__title {
  display: block;
  margin-top: 12rpx;
  color: #f3f1e7;
  font-size: 40rpx;
  font-weight: 600;
}

.quadrant-demo-caption__copy {
  display: block;
  margin-top: 10rpx;
  color: rgba(243, 241, 231, 0.68);
  font-size: 24rpx;
  line-height: 1.58;
}

.quadrant-demo-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.quadrant-demo-actions__ghost,
.quadrant-demo-actions__primary {
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.quadrant-demo-actions__ghost {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  color: rgba(243, 241, 231, 0.82);
}

.quadrant-demo-actions__primary {
  flex: 1.15;
  background: linear-gradient(135deg, #f0dfb3, #e9c271);
  color: #17130f;
}
