.venue-detail-page {
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.venue-detail-hero {
  position: relative;
  overflow: hidden;
  margin: 0 -32rpx;
  padding: 0 32rpx 40rpx;
  min-height: 540rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.venue-detail-hero__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.venue-detail-hero__shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(24, 20, 18, 0.22), rgba(24, 20, 18, 0.4) 48%, rgba(11, 10, 10, 0.78) 100%),
    linear-gradient(0deg, rgba(9, 9, 9, 0.4), rgba(9, 9, 9, 0));
}

.venue-detail-hero__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  pointer-events: none;
}

.venue-detail-hero__mist--a {
  top: 70rpx;
  right: 24rpx;
  width: 260rpx;
  height: 220rpx;
  background: rgba(255, 214, 156, 0.14);
}

.venue-detail-hero__mist--b {
  left: 10rpx;
  bottom: 50rpx;
  width: 300rpx;
  height: 180rpx;
  background: rgba(138, 180, 214, 0.12);
}

.detail-hero__back {
  position: relative;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 500;
  align-self: flex-start;
}

.venue-detail-hero__body {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 120rpx;
}

.venue-detail-hero__status {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.venue-detail-hero__title {
  color: #ffffff;
  font-size: 60rpx;
  line-height: 1.02;
  letter-spacing: -1.6rpx;
  font-weight: 700;
}

.venue-detail-hero__copy {
  width: 560rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.55;
}

.venue-hero,
.story {
  margin-top: 26rpx;
  border-radius: 40rpx;
  padding: 30rpx 28rpx;
}

.venue-hero__mood {
  display: block;
  color: rgba(243, 241, 231, 0.52);
  font-size: 22rpx;
}

.venue-hero__title {
  display: block;
  margin-top: 18rpx;
  color: #f3f1e7;
  font-size: 42rpx;
  line-height: 1.28;
}

.venue-hero__stats {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.venue-hero__stat {
  flex: 1;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.04);
}

.venue-hero__label {
  display: block;
  color: rgba(243, 241, 231, 0.44);
  font-size: 22rpx;
}

.venue-hero__value {
  display: block;
  margin-top: 14rpx;
  color: #f3f1e7;
  font-size: 28rpx;
}

.story__title {
  display: block;
  color: #f3f1e7;
  font-size: 28rpx;
  font-weight: 600;
}

.story__mood {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.9);
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 600;
}

.story__copy {
  display: block;
  margin-top: 16rpx;
  color: rgba(243, 241, 231, 0.62);
  font-size: 26rpx;
  line-height: 1.7;
}

.venue-topic-section {
  margin-top: 28rpx;
  padding-bottom: 36rpx;
}

.venue-topic-section__title {
  display: block;
  color: #f3f1e7;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.venue-topic-card {
  margin-top: 18rpx;
  padding: 24rpx 24rpx 26rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.04);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.04);
}

.venue-topic-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.venue-topic-card__status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.venue-topic-card__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.venue-topic-card__dot--live {
  background: #ffffff;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.72);
}

.venue-topic-card__dot--upcoming {
  background: rgba(255, 255, 255, 0.42);
}

.venue-topic-card__status-label,
.venue-topic-card__date {
  color: rgba(243, 241, 231, 0.66);
  font-size: 22rpx;
}

.venue-topic-card__title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 38rpx;
  line-height: 1.18;
  font-weight: 600;
}

.venue-topic-card__meta {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.68);
  font-size: 24rpx;
  line-height: 1.5;
}

.venue-topic-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.venue-topic-card__pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.88);
  font-size: 22rpx;
}
