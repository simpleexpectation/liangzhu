<view class="page-shell venue-detail-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <view class="venue-detail-hero" style="padding-top: {{statusBarHeight + 44}}px;">
    <image class="venue-detail-hero__image" src="{{venue.heroImage}}" mode="aspectFill" />
    <view class="venue-detail-hero__shade"></view>
    <view class="venue-detail-hero__mist venue-detail-hero__mist--a"></view>
    <view class="venue-detail-hero__mist venue-detail-hero__mist--b"></view>
    <view class="detail-hero__back" bindtap="goBack">返回</view>

    <view class="venue-detail-hero__body">
      <text class="venue-detail-hero__status">{{venue.caption}}</text>
      <text class="venue-detail-hero__title">{{venue.name}}</text>
      <text class="venue-detail-hero__copy">当你抵达这里，系统只做两件事：确认你在场，和把打扰降到最低。</text>
    </view>
  </view>
</view>
