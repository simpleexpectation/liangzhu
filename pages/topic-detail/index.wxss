.topic-detail-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ── 渐变 Hero（复用 event-detail 的结构，颜色用色系1）── */
.detail-hero {
  position: relative;
  overflow: hidden;
  margin: 0 -32rpx;
  padding: 0 32rpx 40rpx;
  min-height: 480rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.detail-hero--1 {
  background: linear-gradient(180deg, #6a6480, #b8adc8 70%, #e8a060 100%);
}

.detail-hero__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  animation: drift 8s ease-in-out infinite;
  pointer-events: none;
}

.detail-hero__mist--a {
  top: -40rpx;
  right: 20rpx;
  width: 320rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.2);
}

.detail-hero__mist--b {
  left: 20rpx;
  bottom: 20rpx;
  width: 300rpx;
  height: 200rpx;
  background: rgba(255, 195, 100, 0.22);
  animation-delay: -2.5s;
}

.detail-hero__back {
  position: relative;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 500;
  align-self: flex-start;
}

.detail-hero__body {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 36rpx;
}

.detail-hero__status {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.detail-hero__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.detail-hero__dot--live {
  background: #ffffff;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.8);
}

.detail-hero__dot--upcoming {
  background: rgba(255, 255, 255, 0.5);
}

.detail-hero__status-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.detail-hero__title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -1.5rpx;
  color: #ffffff;
}

.detail-hero__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
}

.detail-hero__initiator {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
}

.detail-hero__meta-rest {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.detail-hero__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-hero__pill {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

/* ── 元信息列表 ── */
.meta-list {
  margin-top: 36rpx;
  border-radius: 28rpx;
  background: #111214;
  overflow: hidden;
}

.meta-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 22rpx 26rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-row__label {
  font-size: 22rpx;
  color: rgba(243, 241, 231, 0.45);
  flex-shrink: 0;
  width: 80rpx;
}

.meta-row__value {
  font-size: 26rpx;
  color: rgba(243, 241, 231, 0.9);
  text-align: right;
  flex: 1;
}

/* ── 内容区块 ── */
.detail-block {
  margin-top: 16rpx;
  border-radius: 28rpx;
  padding: 28rpx;
  background: #111214;
}

.detail-block__title {
  display: block;
  font-size: 22rpx;
  color: rgba(243, 241, 231, 0.45);
  letter-spacing: 0.5rpx;
  margin-bottom: 20rpx;
}

.detail-block__copy {
  display: block;
  font-size: 27rpx;
  color: rgba(243, 241, 231, 0.88);
  line-height: 1.7;
}

/* ── 参与者 ── */
.participants-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.participant {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 110rpx;
}

.participant__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.participant__initial {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(243, 241, 231, 0.88);
}

.participant__name {
  font-size: 22rpx;
  color: rgba(243, 241, 231, 0.82);
  font-weight: 500;
}

.participant__role {
  font-size: 18rpx;
  color: rgba(243, 241, 231, 0.42);
  text-align: center;
  line-height: 1.4;
}

/* ── 固定底部操作栏 ── */
.detail-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  z-index: 20;
}

.detail-footer__rail {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 14rpx 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(96, 59, 20, 0.18), rgba(0, 0, 0, 0)),
    #000000;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 -4rpx 40rpx rgba(0, 0, 0, 0.5);
}

.detail-footer__back {
  padding: 0 24rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(243, 241, 231, 0.7);
  font-size: 26rpx;
  flex-shrink: 0;
}

.detail-footer__cta {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f1eddd, #d8cfb5);
  color: #111111;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-footer__ghost {
  padding: 0 22rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: rgba(243, 241, 231, 0.7);
  font-size: 24rpx;
  flex-shrink: 0;
}
