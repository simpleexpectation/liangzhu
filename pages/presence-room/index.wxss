.presence-room-page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
}

.presence-room-page__glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(96rpx);
  pointer-events: none;
  opacity: 0.72;
}

.presence-room-page__glow--a {
  top: 160rpx;
  right: -50rpx;
  width: 340rpx;
  height: 280rpx;
  background: rgba(248, 213, 157, 0.18);
}

.presence-room-page__glow--b {
  left: -40rpx;
  bottom: 240rpx;
  width: 320rpx;
  height: 260rpx;
  background: rgba(158, 187, 236, 0.14);
}

.presence-room-nav {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.presence-room-nav-card {
  position: relative;
  overflow: hidden;
  padding: 18rpx 20rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 82% 18%, rgba(245, 225, 170, 0.12), transparent 22%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 18rpx 40rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(18rpx);
}

.presence-room-nav-card__glow {
  position: absolute;
  top: -28rpx;
  right: 4rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 225, 170, 0.14), rgba(245, 225, 170, 0));
  filter: blur(18rpx);
}

.presence-room-nav__back {
  min-width: 88rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #f3f1e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  position: relative;
  z-index: 1;
}

.presence-room-nav__copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 4rpx;
}

.presence-room-nav__title {
  color: #f3f1e7;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 600;
  letter-spacing: -1rpx;
}

.presence-room-nav__sub {
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
  line-height: 1.45;
}

.presence-room-hero {
  margin-top: 34rpx;
  position: relative;
  overflow: hidden;
  padding: 30rpx 28rpx 28rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 82% 18%, rgba(244, 232, 182, 0.26), transparent 22%),
    radial-gradient(circle at 18% 82%, rgba(206, 176, 160, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(120, 107, 96, 0.52), rgba(93, 81, 73, 0.62));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 20rpx 48rpx rgba(0, 0, 0, 0.16);
  backdrop-filter: blur(18rpx);
}

.presence-room-hero__glow {
  position: absolute;
  top: -24rpx;
  right: 8rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 225, 170, 0.24), rgba(245, 225, 170, 0));
  filter: blur(18rpx);
}

.presence-room-hero__eyebrow {
  position: relative;
  z-index: 1;
  display: block;
  color: rgba(243, 241, 231, 0.44);
  font-size: 20rpx;
  letter-spacing: 1.2rpx;
}

.presence-room-hero__title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: #f3f1e7;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 600;
  letter-spacing: -1.2rpx;
}

.presence-room-hero__meta {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: rgba(243, 241, 231, 0.54);
  font-size: 22rpx;
}

.presence-room-hero__copy {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 18rpx;
  color: rgba(243, 241, 231, 0.74);
  font-size: 24rpx;
  line-height: 1.65;
}

.presence-room-hero__people {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.presence-room-hero__person {
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.72);
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
}

.presence-room-stream {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
}

.presence-room-message {
  border-radius: 28rpx;
  padding: 22rpx 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.presence-room-message--system {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.presence-room-message--other,
.presence-room-message--self {
  background: rgba(17, 18, 20, 0.82);
}

.presence-room-message--self {
  background: linear-gradient(180deg, rgba(225, 171, 146, 0.9), rgba(212, 167, 141, 0.9));
}

.presence-room-message__system {
  display: block;
  color: rgba(243, 241, 231, 0.58);
  font-size: 22rpx;
  line-height: 1.55;
}

.presence-room-message__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.presence-room-message__name {
  color: #f3f1e7;
  font-size: 24rpx;
  font-weight: 600;
}

.presence-room-message__time {
  color: rgba(243, 241, 231, 0.36);
  font-size: 20rpx;
}

.presence-room-message__body {
  display: block;
  margin-top: 12rpx;
  color: rgba(243, 241, 231, 0.84);
  font-size: 25rpx;
  line-height: 1.7;
}

.presence-room-message--self .presence-room-message__name,
.presence-room-message--self .presence-room-message__body {
  color: #191211;
}

.presence-room-message--self .presence-room-message__time {
  color: rgba(25, 18, 17, 0.48);
}

.presence-room-compose {
  position: sticky;
  bottom: 0;
  margin-top: auto;
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 18rpx 0 calc(12rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(5, 5, 5, 0), rgba(5, 5, 5, 0.9) 36%, rgba(5, 5, 5, 0.98) 100%);
}

.presence-room-compose__field {
  flex: 1;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  backdrop-filter: blur(14rpx);
}

.presence-room-compose__input {
  width: 100%;
  color: #f3f1e7;
  font-size: 24rpx;
}

.presence-room-compose__placeholder {
  color: rgba(243, 241, 231, 0.34);
}

.presence-room-compose__send {
  min-width: 132rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f3e5cc, #e8c9a3);
  color: #1a1411;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.14);
}
