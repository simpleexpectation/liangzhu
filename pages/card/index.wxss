.space-page {
  position: relative;
  overflow: hidden;
}

.space-page__top-mask {
  display: none;
}

.home-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 14;
}

.home-hero-nav {
  display: block;
  background: transparent;
}

.tab-switch {
  display: flex;
  gap: 32rpx;
  align-items: flex-end;
  padding-top: 8rpx;
  position: relative;
  z-index: 3;
}

.tab-switch--floating {
  padding: 14rpx 0 18rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  backdrop-filter: none;
}

.tab-switch__item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: rgba(243, 241, 231, 0.24);
  transition: color 0.18s ease, opacity 0.18s ease;
}

.tab-switch__item--active {
  color: #f3f1e7;
}

.tab-switch__label {
  font-size: 78rpx;
  line-height: 0.95;
  letter-spacing: -2rpx;
  font-weight: 600;
}

.tab-switch__eyebrow {
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
  color: rgba(243, 241, 231, 0.34);
}

.tab-switch__item--active .tab-switch__eyebrow {
  color: rgba(243, 241, 231, 0.56);
}

.topic-section-swiper {
  height: calc(100vh - 24rpx);
  width: calc(100% + 64rpx);
  margin-left: -32rpx;
}

.topic-section-scroll {
  height: 100%;
  box-sizing: border-box;
  width: 100%;
}

.topic-feed {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 0;
  margin-left: 0;
  margin-right: 0;
  padding-bottom: calc(52rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 2;
}

.topic-feed--hero {
  padding-top: 0;
}

.topic-feed--week {
  gap: 22rpx;
}

.week-timeline {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 34rpx;
}

.week-timeline--hero {
  margin: 0 0 0;
  margin-left: 0;
  margin-right: 0;
  padding: 0 32rpx 18rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  backdrop-filter: none;
}

.week-timeline__track {
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
  width: 100%;
}

.week-timeline__dot {
  width: 84rpx;
  min-width: 0;
  height: 96rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.02);
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, box-shadow 180ms ease, background 180ms ease;
}

.week-timeline__dot--enabled {
  background: rgba(255, 255, 255, 0.1);
}

.week-timeline__dot--active {
  background:
    radial-gradient(circle at 50% 38%, rgba(248, 241, 200, 0.96), rgba(230, 234, 155, 0.88) 62%, rgba(206, 213, 123, 0.9) 100%);
  box-shadow:
    0 0 32rpx rgba(231, 229, 155, 0.28),
    0 0 60rpx rgba(231, 229, 155, 0.1);
}

.week-timeline__dot--pressed {
  transform: translateY(3rpx) scale(0.97);
}

.week-timeline__weekday {
  color: rgba(243, 241, 231, 0.42);
  font-size: 16rpx;
  letter-spacing: 1rpx;
  line-height: 1;
}

.week-timeline__day {
  color: rgba(243, 241, 231, 0.78);
  font-size: 28rpx;
  line-height: 1;
}

.week-timeline__dot--active .week-timeline__weekday,
.week-timeline__dot--active .week-timeline__day {
  color: #1f1b18;
}

.week-empty {
  padding: 34rpx 28rpx;
  border-radius: 34rpx;
}

.week-empty__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.34);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.week-empty__title {
  display: block;
  margin-top: 18rpx;
  color: #f3f1e7;
  font-size: 42rpx;
  line-height: 1.12;
  letter-spacing: -1.2rpx;
  font-weight: 600;
}

.week-empty__copy {
  display: block;
  margin-top: 14rpx;
  max-width: 520rpx;
  color: rgba(243, 241, 231, 0.54);
  font-size: 24rpx;
  line-height: 1.55;
}

.topic-film-card {
  position: relative;
  overflow: hidden;
  min-height: 1160rpx;
  padding: 38rpx 32rpx 40rpx;
  padding-top: 88rpx;
  border-radius: 56rpx;
  display: flex;
  flex-direction: column;
  transform: translateY(0) scale(1);
  box-shadow:
    0 28rpx 84rpx rgba(0, 0, 0, 0.2),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.05);
  transition: transform 180ms ease, box-shadow 220ms ease;
}

.topic-film-card--hero {
  margin-top: 0;
  min-height: 1200rpx;
  padding-top: 112rpx;
  border-radius: 0 0 56rpx 56rpx;
}

.topic-film-card--pressed {
  transform: translateY(8rpx) scale(0.985);
}

.topic-film-card--0 {
  background:
    radial-gradient(circle at 78% 16%, rgba(255, 245, 186, 0.22), transparent 20%),
    radial-gradient(circle at 70% 70%, rgba(224, 180, 134, 0.3), transparent 22%),
    linear-gradient(180deg, #687985 0%, #7a8891 56%, #c4aa90 100%);
}

.topic-film-card--1 {
  background:
    radial-gradient(circle at 82% 12%, rgba(253, 231, 182, 0.2), transparent 18%),
    radial-gradient(circle at 44% 72%, rgba(148, 92, 47, 0.28), transparent 24%),
    linear-gradient(180deg, #2d231d 0%, #6d3516 52%, #c17a35 100%);
}

.topic-film-card--2 {
  background:
    radial-gradient(circle at 80% 14%, rgba(255, 241, 204, 0.18), transparent 20%),
    radial-gradient(circle at 24% 76%, rgba(234, 188, 153, 0.2), transparent 22%),
    linear-gradient(180deg, #6f665f 0%, #aa8f7d 52%, #d9bea4 100%);
}

.topic-film-card--3 {
  background:
    radial-gradient(circle at 82% 16%, rgba(255, 229, 176, 0.2), transparent 18%),
    radial-gradient(circle at 38% 78%, rgba(182, 127, 84, 0.24), transparent 20%),
    linear-gradient(180deg, #5d4a44 0%, #99786e 56%, #d0b08e 100%);
}

.topic-film-card--4 {
  background:
    radial-gradient(circle at 82% 14%, rgba(255, 245, 186, 0.18), transparent 18%),
    radial-gradient(circle at 26% 76%, rgba(200, 143, 121, 0.24), transparent 20%),
    linear-gradient(180deg, #66655d 0%, #8d867e 52%, #c1a78c 100%);
}

.topic-film-card__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(56rpx);
  pointer-events: none;
  transform: translate3d(0, 0, 0);
}

.topic-film-card__mist--a {
  top: 80rpx;
  right: 30rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(244, 232, 156, 0.3);
  animation: cardGlowFloatA 20s ease-in-out infinite alternate;
}

.topic-film-card__mist--b {
  left: 0;
  bottom: 120rpx;
  width: 360rpx;
  height: 280rpx;
  background: rgba(213, 223, 234, 0.24);
  animation: cardGlowFloatB 26s ease-in-out infinite alternate;
}

.topic-film-card__body {
  position: relative;
  z-index: 2;
  margin-top: auto;
  display: flex;
  flex-direction: column;
  min-height: 398rpx;
  justify-content: flex-end;
}

.topic-film-card__title {
  display: block;
  max-width: 538rpx;
  color: #fff;
  font-size: 52rpx;
  line-height: 1.06;
  letter-spacing: -1.4rpx;
  font-weight: 700;
  min-height: 110rpx;
  max-height: 110rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  text-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.12);
}

.topic-film-card__footer-cluster {
  margin-top: 22rpx;
  padding-top: 0;
}

.topic-film-card__meta-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 0;
}

.topic-film-card__meta-pill {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
  font-size: 17rpx;
  line-height: 1;
}

.topic-film-card__actions {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1.2fr 0.9fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.topic-film-card__action {
  min-height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.8);
  font-size: 20rpx;
  font-weight: 600;
  backdrop-filter: blur(12rpx);
}

.topic-film-card__action--primary {
  background: rgba(255, 255, 255, 0.92);
  color: #141210;
  border-color: transparent;
}

.topic-film-card__footnote {
  position: relative;
  z-index: 2;
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 16rpx;
  line-height: 1.45;
}

.launch-home {
  margin-top: 8rpx;
  padding: 8rpx 32rpx 24rpx;
}

.launch-home__head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 22rpx;
}

.launch-home__eyebrow {
  color: rgba(243, 241, 231, 0.36);
  font-size: 16rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.launch-home__title {
  color: #f3f1e7;
  font-size: 44rpx;
  line-height: 1;
  letter-spacing: -1.2rpx;
  font-weight: 600;
}

.launch-home__copy {
  color: rgba(243, 241, 231, 0.52);
  font-size: 21rpx;
  line-height: 1.55;
  max-width: 560rpx;
}

.launch-home__grid {
  display: grid;
  gap: 18rpx;
}

.launch-home__card {
  position: relative;
  overflow: hidden;
  min-height: 256rpx;
  padding: 24rpx 24rpx 26rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow:
    0 24rpx 60rpx rgba(0, 0, 0, 0.18),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.05);
}

.launch-home__card--primary {
  background:
    radial-gradient(circle at 82% 18%, rgba(246, 228, 170, 0.18), transparent 22%),
    radial-gradient(circle at 20% 84%, rgba(191, 206, 223, 0.12), transparent 26%),
    linear-gradient(180deg, rgba(112, 124, 134, 0.9), rgba(155, 132, 118, 0.92) 56%, rgba(194, 162, 120, 0.94) 100%);
}

.launch-home__card-eyebrow {
  color: rgba(255, 255, 255, 0.54);
  font-size: 16rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.launch-home__card-title {
  color: #fff;
  font-size: 32rpx;
  line-height: 1.14;
  letter-spacing: -0.8rpx;
  font-weight: 600;
  max-width: 500rpx;
}

.launch-home__card-copy {
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  line-height: 1.58;
  max-width: 520rpx;
}

.launch-home__card-action {
  margin-top: auto;
  align-self: flex-start;
  min-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  color: #171312;
  font-size: 19rpx;
  font-weight: 600;
}

@keyframes cardGlowFloatA {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 0.82;
  }
  48% {
    transform: translate3d(-52rpx, 44rpx, 0) scale(1.16);
    opacity: 1;
  }
  100% {
    transform: translate3d(30rpx, 78rpx, 0) scale(1.06);
    opacity: 0.86;
  }
}

@keyframes cardGlowFloatB {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 0.68;
  }
  52% {
    transform: translate3d(60rpx, -34rpx, 0) scale(1.12);
    opacity: 0.88;
  }
  100% {
    transform: translate3d(-36rpx, -64rpx, 0) scale(1.06);
    opacity: 0.72;
  }
}

.opening-screen {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  overflow: hidden;
  background: #030403;
  color: #f6f4ea;
  opacity: 1;
  transform: translate3d(0, 0, 0);
  transition: opacity 520ms ease, transform 520ms ease;
}

.opening-screen--leaving {
  opacity: 0;
  transform: translate3d(0, -14rpx, 0);
  pointer-events: none;
}

.opening-screen__flow,
.opening-screen__grain {
  position: absolute;
  pointer-events: none;
}

.opening-screen__flow {
  border-radius: 50%;
  filter: blur(44rpx);
  opacity: 0.86;
  transform: translate3d(0, 0, 0);
}

.opening-screen__flow--a {
  top: -14%;
  right: -28%;
  width: 760rpx;
  height: 720rpx;
  background:
    radial-gradient(circle at 40% 42%, rgba(246, 236, 162, 0.38), transparent 33%),
    radial-gradient(circle at 64% 58%, rgba(161, 187, 207, 0.2), transparent 45%);
  animation: openingFlowA 8s ease-in-out infinite alternate;
}

.opening-screen__flow--b {
  left: -34%;
  bottom: -20%;
  width: 860rpx;
  height: 740rpx;
  background:
    radial-gradient(circle at 56% 44%, rgba(223, 165, 111, 0.26), transparent 36%),
    radial-gradient(circle at 44% 58%, rgba(210, 224, 235, 0.16), transparent 48%);
  animation: openingFlowB 9s ease-in-out infinite alternate;
}

.opening-screen__flow--c {
  left: 18%;
  top: 34%;
  width: 520rpx;
  height: 520rpx;
  background: radial-gradient(circle, rgba(247, 232, 168, 0.18), transparent 58%);
  animation: openingFlowC 6.8s ease-in-out infinite alternate;
}

.opening-screen__grain {
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background-image:
    radial-gradient(rgba(255, 248, 220, 0.24) 1rpx, transparent 1rpx),
    radial-gradient(rgba(206, 226, 255, 0.13) 1rpx, transparent 1rpx);
  background-size: 132rpx 164rpx, 214rpx 246rpx;
  background-position: 18rpx 36rpx, 96rpx 160rpx;
  opacity: 0.18;
  animation: openingGrainMove 14s linear infinite;
}

.opening-screen__copy {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 188rpx 42rpx calc(78rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.opening-screen__line {
  display: block;
  color: rgba(246, 244, 234, 0);
  font-size: 54rpx;
  line-height: 1.24;
  letter-spacing: 0;
  font-weight: 800;
  white-space: nowrap;
  text-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.48);
  animation: openingTextIn 1.25s ease forwards;
}

.opening-screen__line--1 {
  animation-delay: 0.28s;
}

.opening-screen__line--2 {
  animation-delay: 1.08s;
}

.opening-screen__line--3 {
  animation-delay: 2.18s;
}

.opening-screen__line--4 {
  animation-delay: 3.02s;
}

.opening-screen__line--5 {
  animation-delay: 3.86s;
}

.opening-screen__line--6 {
  animation-delay: 4.7s;
}

.opening-screen__line--7 {
  animation-delay: 5.64s;
}

.opening-screen__spacer {
  height: 54rpx;
}

.opening-screen__spacer--final {
  height: 64rpx;
}

.opening-screen__cta {
  align-self: flex-start;
  margin-top: 70rpx;
  min-height: 82rpx;
  padding: 0 34rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(246, 244, 234, 0.92);
  color: #11110f;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 800;
  opacity: 0;
  transform: translate3d(0, 18rpx, 0);
  box-shadow:
    0 0 42rpx rgba(246, 226, 154, 0.22),
    0 22rpx 60rpx rgba(0, 0, 0, 0.36);
  animation: openingCtaIn 0.9s ease 6.2s forwards;
}

.opening-guide {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 188rpx 42rpx calc(78rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  justify-content: center;
  opacity: 1;
  transform: translate3d(0, 0, 0);
  filter: blur(0);
  transition: opacity 560ms ease, transform 560ms ease, filter 560ms ease;
}

.opening-guide--leaving {
  opacity: 0;
  transform: translate3d(0, -18rpx, 0);
  filter: blur(8rpx);
  pointer-events: none;
}

.opening-guide__text {
  display: flex;
  flex-direction: column;
}

.opening-guide__line {
  animation-duration: 1.35s;
}

.opening-guide__line--a {
  animation-name: openingTextIn;
}

.opening-guide__line--b {
  animation-name: openingTextInAlt;
}

.opening-guide__spacer {
  height: 54rpx;
}

.opening-guide__button-group {
  align-self: flex-start;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 70rpx;
  opacity: 0;
  transform: translate3d(0, 18rpx, 0);
}

.opening-guide__button-group--a {
  animation: openingCtaIn 0.9s ease 4.7s forwards;
}

.opening-guide__button-group--b {
  animation: openingCtaInAlt 0.9s ease 4.7s forwards;
}

.opening-guide--leaving .opening-guide__button-group {
  animation: none;
  opacity: 0;
  transform: translate3d(0, -10rpx, 0);
  transition: opacity 260ms ease, transform 260ms ease;
}

.opening-guide__text-button,
.opening-guide__nav-button {
  min-height: 82rpx;
  padding: 0 34rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  line-height: 1;
  font-weight: 800;
}

.opening-guide__text-button,
.opening-guide__nav-button--primary {
  background: rgba(246, 244, 234, 0.92);
  color: #11110f;
  box-shadow:
    0 0 42rpx rgba(246, 226, 154, 0.22),
    0 22rpx 60rpx rgba(0, 0, 0, 0.36);
}

.opening-guide__nav-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.opening-guide__nav-button--ghost {
  background: rgba(246, 244, 234, 0.08);
  color: rgba(246, 244, 234, 0.74);
  border: 1rpx solid rgba(246, 244, 234, 0.12);
}

@keyframes openingTextIn {
  0% {
    color: rgba(246, 244, 234, 0);
    opacity: 0;
    transform: translate3d(0, 24rpx, 0);
    filter: blur(12rpx);
  }
  100% {
    color: rgba(246, 244, 234, 0.96);
    opacity: 1;
    transform: translate3d(0, 0, 0);
    filter: blur(0);
  }
}

@keyframes openingCtaIn {
  0% {
    opacity: 0;
    transform: translate3d(0, 18rpx, 0);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes openingTextInAlt {
  0% {
    color: rgba(246, 244, 234, 0);
    opacity: 0;
    transform: translate3d(0, 24rpx, 0);
    filter: blur(12rpx);
  }
  100% {
    color: rgba(246, 244, 234, 0.96);
    opacity: 1;
    transform: translate3d(0, 0, 0);
    filter: blur(0);
  }
}

@keyframes openingCtaInAlt {
  0% {
    opacity: 0;
    transform: translate3d(0, 18rpx, 0);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes openingGuideIn {
  0% {
    opacity: 0;
    transform: translate3d(0, 28rpx, 0);
    filter: blur(10rpx);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    filter: blur(0);
  }
}

@keyframes openingGuidePanelFlow {
  0% {
    transform: translate3d(-54rpx, -34rpx, 0) scale(1);
    opacity: 0.56;
  }
  48% {
    transform: translate3d(66rpx, 38rpx, 0) scale(1.1);
    opacity: 0.82;
  }
  100% {
    transform: translate3d(-32rpx, 72rpx, 0) scale(1.05);
    opacity: 0.64;
  }
}

@keyframes openingFlowA {
  0% {
    transform: translate3d(-26rpx, -18rpx, 0) scale(1);
    opacity: 0.66;
  }
  50% {
    transform: translate3d(-112rpx, 76rpx, 0) scale(1.2);
    opacity: 0.98;
  }
  100% {
    transform: translate3d(-42rpx, 146rpx, 0) scale(1.08);
    opacity: 0.78;
  }
}

@keyframes openingFlowB {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 0.62;
  }
  48% {
    transform: translate3d(104rpx, -92rpx, 0) scale(1.16);
    opacity: 0.94;
  }
  100% {
    transform: translate3d(58rpx, -164rpx, 0) scale(1.08);
    opacity: 0.74;
  }
}

@keyframes openingFlowC {
  0% {
    transform: translate3d(-34rpx, 52rpx, 0) scale(0.88);
    opacity: 0.42;
  }
  100% {
    transform: translate3d(66rpx, -46rpx, 0) scale(1.24);
    opacity: 0.82;
  }
}

@keyframes openingGrainMove {
  0% {
    transform: translate3d(0, 0, 0);
    opacity: 0.14;
  }
  50% {
    opacity: 0.26;
  }
  100% {
    transform: translate3d(-44rpx, 58rpx, 0);
    opacity: 0.14;
  }
}
