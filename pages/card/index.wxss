.space-page {
  position: relative;
}

.space-page__top-mask {
  display: none;
}

.tab-switch {
  display: flex;
  gap: 32rpx;
  align-items: flex-end;
  padding-top: 8rpx;
  position: relative;
  z-index: 3;
}

.tab-switch__item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: rgba(243, 241, 231, 0.24);
  transition: color 0.18s ease, opacity 0.18s ease;
}

.tab-switch__item--active {
  color: #f3f1e7;
}

.tab-switch__label {
  font-size: 78rpx;
  line-height: 0.95;
  letter-spacing: -2rpx;
  font-weight: 600;
}

.tab-switch__eyebrow {
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
  color: rgba(243, 241, 231, 0.34);
}

.tab-switch__item--active .tab-switch__eyebrow {
  color: rgba(243, 241, 231, 0.56);
}

.topic-section-swiper {
  height: calc(100vh - 180rpx);
}

.topic-section-scroll {
  height: 100%;
  box-sizing: border-box;
}

.topic-feed {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 32rpx;
  padding-bottom: calc(52rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 2;
}

.week-timeline {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 34rpx;
}

.week-timeline__scroll {
  white-space: nowrap;
}

.week-timeline__track {
  display: inline-flex;
  gap: 12rpx;
  min-width: 100%;
}

.week-timeline__dot {
  min-width: 84rpx;
  height: 96rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.02);
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, box-shadow 180ms ease, background 180ms ease;
}

.week-timeline__dot--enabled {
  background: rgba(255, 255, 255, 0.1);
}

.week-timeline__dot--active {
  background:
    radial-gradient(circle at 50% 38%, rgba(248, 241, 200, 0.96), rgba(230, 234, 155, 0.88) 62%, rgba(206, 213, 123, 0.9) 100%);
  box-shadow:
    0 0 32rpx rgba(231, 229, 155, 0.28),
    0 0 60rpx rgba(231, 229, 155, 0.1);
}

.week-timeline__dot--pressed {
  transform: translateY(3rpx) scale(0.97);
}

.week-timeline__weekday {
  color: rgba(243, 241, 231, 0.42);
  font-size: 16rpx;
  letter-spacing: 1rpx;
  line-height: 1;
}

.week-timeline__day {
  color: rgba(243, 241, 231, 0.78);
  font-size: 28rpx;
  line-height: 1;
}

.week-timeline__dot--active .week-timeline__weekday,
.week-timeline__dot--active .week-timeline__day {
  color: #1f1b18;
}

.week-empty {
  padding: 34rpx 28rpx;
  border-radius: 34rpx;
}

.week-empty__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.34);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.week-empty__title {
  display: block;
  margin-top: 18rpx;
  color: #f3f1e7;
  font-size: 42rpx;
  line-height: 1.12;
  letter-spacing: -1.2rpx;
  font-weight: 600;
}

.week-empty__copy {
  display: block;
  margin-top: 14rpx;
  max-width: 520rpx;
  color: rgba(243, 241, 231, 0.54);
  font-size: 24rpx;
  line-height: 1.55;
}

.topic-film-card {
  position: relative;
  overflow: hidden;
  min-height: 1120rpx;
  padding: 36rpx 30rpx 32rpx;
  border-radius: 44rpx;
  display: flex;
  flex-direction: column;
  transform: translateY(0) scale(1);
  box-shadow:
    0 28rpx 84rpx rgba(0, 0, 0, 0.2),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.05);
  transition: transform 180ms ease, box-shadow 220ms ease;
}

.topic-film-card--pressed {
  transform: translateY(8rpx) scale(0.985);
}

.topic-film-card--0 {
  background:
    radial-gradient(circle at 78% 16%, rgba(255, 245, 186, 0.22), transparent 20%),
    radial-gradient(circle at 70% 70%, rgba(224, 180, 134, 0.3), transparent 22%),
    linear-gradient(180deg, #687985 0%, #7a8891 56%, #c4aa90 100%);
}

.topic-film-card--1 {
  background:
    radial-gradient(circle at 82% 12%, rgba(253, 231, 182, 0.2), transparent 18%),
    radial-gradient(circle at 44% 72%, rgba(148, 92, 47, 0.28), transparent 24%),
    linear-gradient(180deg, #2d231d 0%, #6d3516 52%, #c17a35 100%);
}

.topic-film-card--2 {
  background:
    radial-gradient(circle at 80% 14%, rgba(255, 241, 204, 0.18), transparent 20%),
    radial-gradient(circle at 24% 76%, rgba(234, 188, 153, 0.2), transparent 22%),
    linear-gradient(180deg, #6f665f 0%, #aa8f7d 52%, #d9bea4 100%);
}

.topic-film-card--3 {
  background:
    radial-gradient(circle at 82% 16%, rgba(255, 229, 176, 0.2), transparent 18%),
    radial-gradient(circle at 38% 78%, rgba(182, 127, 84, 0.24), transparent 20%),
    linear-gradient(180deg, #5d4a44 0%, #99786e 56%, #d0b08e 100%);
}

.topic-film-card--4 {
  background:
    radial-gradient(circle at 82% 14%, rgba(255, 245, 186, 0.18), transparent 18%),
    radial-gradient(circle at 26% 76%, rgba(200, 143, 121, 0.24), transparent 20%),
    linear-gradient(180deg, #66655d 0%, #8d867e 52%, #c1a78c 100%);
}

.topic-film-card__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(56rpx);
  pointer-events: none;
}

.topic-film-card__mist--a {
  top: 80rpx;
  right: 30rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(244, 232, 156, 0.18);
}

.topic-film-card__mist--b {
  left: 0;
  bottom: 120rpx;
  width: 360rpx;
  height: 280rpx;
  background: rgba(213, 223, 234, 0.14);
}

.topic-film-card__scene {
  position: relative;
  z-index: 2;
}

.topic-film-card__status-line {
  display: flex;
  align-items: center;
}

.topic-film-card__pill {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 600;
}

.topic-film-card__people-stack {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx 16rpx;
  margin-top: 18rpx;
}

.topic-film-card__person-card {
  min-height: 116rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(18rpx);
}

.topic-film-card__person-card--0 {
  transform: translate3d(0, 0, 0) rotate(-1deg);
}

.topic-film-card__person-card--1 {
  transform: translate3d(0, 18rpx, 0) rotate(0.6deg);
}

.topic-film-card__person-card--2 {
  transform: translate3d(8rpx, 2rpx, 0) rotate(0.3deg);
}

.topic-film-card__person-card--3 {
  transform: translate3d(-4rpx, 20rpx, 0) rotate(-0.4deg);
}

.topic-film-card__person-card--4 {
  transform: translate3d(6rpx, -2rpx, 0) rotate(0.8deg);
}

.topic-film-card__person-card--5 {
  transform: translate3d(-2rpx, 16rpx, 0) rotate(-0.6deg);
}

.topic-film-card__person-name {
  display: block;
  color: rgba(255, 255, 255, 0.94);
  font-size: 31rpx;
  line-height: 1.15;
  font-weight: 700;
}

.topic-film-card__person-line {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 21rpx;
  line-height: 1.45;
}

.topic-film-card__body {
  position: relative;
  z-index: 2;
  margin-top: 170rpx;
}

.topic-film-card__title {
  display: block;
  max-width: 600rpx;
  color: #fff;
  font-size: 70rpx;
  line-height: 1.08;
  letter-spacing: -2.2rpx;
  font-weight: 700;
}

.topic-film-card__meta-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.topic-film-card__meta-pill {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1;
}

.topic-film-card__actions {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1.2fr 0.9fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.topic-film-card__action {
  min-height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  font-weight: 600;
  backdrop-filter: blur(12rpx);
}

.topic-film-card__action--primary {
  background: rgba(255, 255, 255, 0.92);
  color: #141210;
  border-color: transparent;
}

.topic-film-card__footnote {
  position: relative;
  z-index: 2;
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.52);
  font-size: 20rpx;
  line-height: 1.45;
}

.launch-home {
  margin-top: 8rpx;
  padding: 8rpx 0 24rpx;
}

.launch-home__head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 22rpx;
}

.launch-home__eyebrow {
  color: rgba(243, 241, 231, 0.36);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.launch-home__title {
  color: #f3f1e7;
  font-size: 52rpx;
  line-height: 1;
  letter-spacing: -1.8rpx;
  font-weight: 600;
}

.launch-home__copy {
  color: rgba(243, 241, 231, 0.52);
  font-size: 24rpx;
  line-height: 1.55;
  max-width: 560rpx;
}

.launch-home__grid {
  display: grid;
  gap: 18rpx;
}

.launch-home__card {
  position: relative;
  overflow: hidden;
  min-height: 280rpx;
  padding: 26rpx 26rpx 28rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  box-shadow:
    0 24rpx 60rpx rgba(0, 0, 0, 0.18),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.05);
}

.launch-home__card--primary {
  background:
    radial-gradient(circle at 82% 18%, rgba(246, 228, 170, 0.18), transparent 22%),
    radial-gradient(circle at 20% 84%, rgba(191, 206, 223, 0.12), transparent 26%),
    linear-gradient(180deg, rgba(112, 124, 134, 0.9), rgba(155, 132, 118, 0.92) 56%, rgba(194, 162, 120, 0.94) 100%);
}

.launch-home__card--secondary {
  background:
    radial-gradient(circle at 80% 16%, rgba(255, 239, 196, 0.14), transparent 20%),
    radial-gradient(circle at 18% 82%, rgba(196, 176, 150, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(54, 44, 40, 0.96), rgba(92, 72, 62, 0.94) 54%, rgba(132, 100, 80, 0.92) 100%);
}

.launch-home__card-eyebrow {
  color: rgba(255, 255, 255, 0.54);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.launch-home__card-title {
  color: #fff;
  font-size: 42rpx;
  line-height: 1.12;
  letter-spacing: -1.2rpx;
  font-weight: 600;
  max-width: 500rpx;
}

.launch-home__card-copy {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.58;
  max-width: 520rpx;
}

.launch-home__card-action {
  margin-top: auto;
  align-self: flex-start;
  min-height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  color: #171312;
  font-size: 24rpx;
  font-weight: 600;
}
