<view class="page-shell space-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <view class="space-page__top-mask"></view>

  <view class="home-hero-overlay">
    <nav-shell class="home-hero-nav">
      <view class="tab-switch tab-switch--floating">
        <view
          class="tab-switch__item {{activeTab === 'tonight' ? 'tab-switch__item--active' : ''}}"
          bindtap="switchTab"
          data-tab="tonight"
        >
          <text class="tab-switch__eyebrow">Tonight</text>
          <text class="tab-switch__label">今晚</text>
        </view>
        <view
          class="tab-switch__item {{activeTab === 'week' ? 'tab-switch__item--active' : ''}}"
          bindtap="switchTab"
          data-tab="week"
        >
          <text class="tab-switch__eyebrow">This Week</text>
          <text class="tab-switch__label">这周</text>
        </view>
      </view>
    </nav-shell>
  </view>

  <swiper class="topic-section-swiper" current="{{activeTabIndex}}" duration="360" bindchange="onTopicSectionChange">
    <swiper-item>
      <scroll-view scroll-y class="topic-section-scroll">
        <view class="topic-feed topic-feed--hero">
          <view
            wx:for="{{visibleTopics}}"
            wx:key="id"
            class="topic-film-card topic-film-card--{{index % 5}} {{index === 0 ? 'topic-film-card--hero' : ''}} {{pressedTopicId === item.id ? 'topic-film-card--pressed' : ''}}"
            data-id="{{item.id}}"
            bindtouchstart="pressTopicCard"
            bindtouchend="releaseTopicCard"
            bindtouchcancel="releaseTopicCard"
            bindtap="goTopicDetail"
          >
            <view class="topic-film-card__mist topic-film-card__mist--a"></view>
            <view class="topic-film-card__mist topic-film-card__mist--b"></view>

            <view class="topic-film-card__body">
              <text class="topic-film-card__title">{{item.title}}</text>
              <view class="topic-film-card__footer-cluster">
                <view class="topic-film-card__meta-pills">
                  <text class="topic-film-card__meta-pill">{{item.initiator}} 发起</text>
                  <text class="topic-film-card__meta-pill">{{item.time}}</text>
                  <text class="topic-film-card__meta-pill">{{item.location}}</text>
                </view>

                <view class="topic-film-card__actions">
                  <view class="topic-film-card__action topic-film-card__action--primary" data-id="{{item.id}}" catchtap="joinTopic">加入今晚</view>
                  <view class="topic-film-card__action" data-id="{{item.id}}" catchtap="rememberTopic">先记住</view>
                </view>

                <text class="topic-film-card__footnote">{{item.rules}}</text>
              </view>
            </view>
          </view>

          <view class="launch-home">
            <view class="launch-home__head">
              <text class="launch-home__eyebrow">Raise a fire</text>
              <text class="launch-home__title">升起篝火</text>
              <text class="launch-home__copy">不必先把机制想得很完整，先把第一束火点起来。</text>
            </view>

            <view class="launch-home__grid">
              <view class="launch-home__card launch-home__card--primary" bindtap="openLaunchDraft">
                <text class="launch-home__card-eyebrow">Campfire card</text>
                <text class="launch-home__card-title">升起一场今晚的篝火</text>
                <text class="launch-home__card-copy">先定时间、人数和方式，把这场见面点起来。</text>
                <view class="launch-home__card-action">去升起</view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </swiper-item>

    <swiper-item>
      <scroll-view scroll-y class="topic-section-scroll">
        <view class="topic-feed topic-feed--hero topic-feed--week">
          <view class="week-timeline week-timeline--hero">
            <view class="week-timeline__track">
              <view
                wx:for="{{fullCalendarDays}}"
                wx:key="key"
                class="week-timeline__dot {{selectedDateKey === item.key ? 'week-timeline__dot--active' : ''}} {{item.hasTopic ? 'week-timeline__dot--enabled' : ''}} {{pressedDateKey === item.key ? 'week-timeline__dot--pressed' : ''}}"
                data-key="{{item.key}}"
                bindtouchstart="pressCalendarDate"
                bindtouchend="releaseCalendarDate"
                bindtouchcancel="releaseCalendarDate"
                bindtap="selectCalendarDate"
              >
                <text class="week-timeline__weekday">{{item.weekday}}</text>
                <text class="week-timeline__day">{{item.day}}</text>
              </view>
            </view>
          </view>

          <block wx:if="{{weekTopics.length}}">
            <view
              wx:for="{{weekTopics}}"
              wx:key="id"
              class="topic-film-card topic-film-card--week topic-film-card--{{index % 5}} {{index === 0 ? 'topic-film-card--hero' : ''}} {{pressedTopicId === item.id ? 'topic-film-card--pressed' : ''}}"
              data-id="{{item.id}}"
              bindtouchstart="pressTopicCard"
              bindtouchend="releaseTopicCard"
              bindtouchcancel="releaseTopicCard"
              bindtap="goTopicDetail"
            >
              <view class="topic-film-card__mist topic-film-card__mist--a"></view>
              <view class="topic-film-card__mist topic-film-card__mist--b"></view>

              <view class="topic-film-card__body">
                <text class="topic-film-card__title">{{item.title}}</text>
                <view class="topic-film-card__footer-cluster">
                  <view class="topic-film-card__meta-pills">
                    <text class="topic-film-card__meta-pill">{{item.initiator}} 发起</text>
                    <text class="topic-film-card__meta-pill">{{item.time}}</text>
                    <text class="topic-film-card__meta-pill">{{item.location}}</text>
                  </view>

                  <view class="topic-film-card__actions">
                    <view class="topic-film-card__action topic-film-card__action--primary" data-id="{{item.id}}" catchtap="joinTopic">加入这周</view>
                    <view class="topic-film-card__action" data-id="{{item.id}}" catchtap="rememberTopic">先记住</view>
                  </view>

                  <text class="topic-film-card__footnote">{{item.rules}}</text>
                </view>
              </view>
            </view>
          </block>

          <view wx:else class="week-empty glass-panel">
            <text class="week-empty__eyebrow">Nothing here yet</text>
            <text class="week-empty__title">这一天还没有名片</text>
            <text class="week-empty__copy">你可以换一天看看，或者直接从下面升起一束新的火。</text>
          </view>

          <view class="launch-home">
            <view class="launch-home__head">
              <text class="launch-home__eyebrow">Raise a fire</text>
              <text class="launch-home__title">升起篝火</text>
              <text class="launch-home__copy">看到这周的卡片之后，如果你也想点起一束火，就从这里开始。</text>
            </view>

            <view class="launch-home__grid">
              <view class="launch-home__card launch-home__card--primary" bindtap="openLaunchDraft">
                <text class="launch-home__card-eyebrow">Campfire card</text>
                <text class="launch-home__card-title">升起一场今晚的篝火</text>
                <text class="launch-home__card-copy">把第一场时间、人数和形式先定下来。</text>
                <view class="launch-home__card-action">去升起</view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>
</view>

<view wx:if="{{showOpening}}" class="opening-screen {{openingLeaving ? 'opening-screen--leaving' : ''}}">
  <view class="opening-screen__flow opening-screen__flow--a"></view>
  <view class="opening-screen__flow opening-screen__flow--b"></view>
  <view class="opening-screen__flow opening-screen__flow--c"></view>
  <view class="opening-screen__grain"></view>

  <view wx:if="{{openingStage === 'origin'}}" class="opening-screen__copy">
    <text class="opening-screen__line opening-screen__line--1">五千年前的良渚，</text>
    <text class="opening-screen__line opening-screen__line--2">人们也许也是这样相遇的。</text>

    <view class="opening-screen__spacer"></view>

    <text class="opening-screen__line opening-screen__line--3">天黑之后，</text>
    <text class="opening-screen__line opening-screen__line--4">有人点起火，</text>
    <text class="opening-screen__line opening-screen__line--5">有人看见火，</text>
    <text class="opening-screen__line opening-screen__line--6">于是走过去。</text>

    <view class="opening-screen__spacer opening-screen__spacer--final"></view>

    <text class="opening-screen__line opening-screen__line--7">今晚良渚见一面。</text>

    <view class="opening-screen__cta" bindtap="startOpeningGuide">
      <text>走近一点</text>
    </view>
  </view>

  <view wx:else class="opening-screen__copy opening-guide {{openingGuideLeaving ? 'opening-guide--leaving' : ''}}">
    <view class="opening-guide__text">
      <block wx:for="{{currentOpeningGuide.lines}}" wx:key="index">
        <view wx:if="{{item === ''}}" class="opening-guide__spacer"></view>
        <text
          wx:else
          class="opening-screen__line opening-guide__line opening-guide__line--{{openingGuideMotion}}"
          style="animation-delay: {{0.26 + index * 0.46}}s;"
        >{{item}}</text>
      </block>
    </view>

    <view class="opening-guide__button-group opening-guide__button-group--{{openingGuideMotion}}">
      <view
        wx:for="{{currentOpeningGuide.buttons}}"
        wx:key="action"
        class="opening-guide__text-button"
        data-action="{{item.action}}"
        bindtap="handleOpeningGuideAction"
      >{{item.text}}</view>
    </view>
  </view>
</view>
