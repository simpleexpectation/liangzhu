<view class="blackhole-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <view class="presence-shell presence-shell--light">
    <view class="presence-shell__glow presence-shell__glow--a"></view>
    <view class="presence-shell__glow presence-shell__glow--b"></view>

    <nav-shell compact>
      <view class="presence-subtabs">
        <view class="presence-subtabs__item {{activeSubtab === 'places' ? 'presence-subtabs__item--active' : ''}}" data-tab="places" bindtap="switchSubtab">
          <text class="presence-subtabs__eyebrow">PLACES</text>
          <text class="presence-subtabs__label">地点</text>
        </view>
        <view class="presence-subtabs__item {{activeSubtab === 'people' ? 'presence-subtabs__item--active' : ''}}" data-tab="people" bindtap="switchSubtab">
          <text class="presence-subtabs__eyebrow">GOOD PEOPLE</text>
          <text class="presence-subtabs__label">好人</text>
        </view>
      </view>
    </nav-shell>

    <scroll-view scroll-y class="presence-section-scroll presence-section-scroll--single">
      <block wx:if="{{activeSubtab === 'places'}}">
        <view class="presence-spaces">
          <view class="venue-page-head venue-page-head--presence">
            <text class="venue-page-head__eyebrow">Today in spaces</text>
          </view>

          <view class="venue-list">
            <view
              wx:for="{{venues}}"
              wx:key="id"
              class="venue-stage"
              data-id="{{item.id}}"
              bindtap="goVenueDetail"
            >
              <view class="venue-stage__head">
                <text class="venue-stage__caption">{{item.caption}}</text>
              </view>

              <view class="venue-stage__card venue-stage__card--{{index}}">
                <image class="venue-stage__image" src="{{item.heroImage}}" mode="aspectFill" />
                <view class="venue-stage__shade"></view>
                <view class="venue-stage__glow"></view>
                <view class="venue-stage__body">
                  <text class="venue-stage__eyebrow">{{item.cluster}}</text>
                  <text class="venue-stage__title">{{item.name}}</text>
                  <text class="venue-stage__copy">{{item.mood}}</text>
                  <view class="venue-stage__meta">
                    <text class="venue-stage__meta-pill">适合：{{item.bestFor}}</text>
                    <text class="venue-stage__meta-pill">{{item.timePreference}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="venue-recommend-entry" bindtap="openVenueRecommend">
              <view class="venue-recommend-entry__glow"></view>
              <text class="venue-recommend-entry__eyebrow">Co-create a space</text>
              <text class="venue-recommend-entry__title">推荐空间</text>
              <text class="venue-recommend-entry__copy">如果你知道一个适合真实对话发生的地方，也可以推荐给我们。通过官方审核后，它会进入正式空间列表。</text>
              <view class="venue-recommend-entry__footer">
                <text class="venue-recommend-entry__meta">用户推荐 · 官方审核后上线</text>
                <view class="venue-recommend-entry__action">去推荐 →</view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:else>
        <view class="good-people-shell">
          <view class="presence-page-head good-people-head">
            <text class="presence-page-head__copy">先看见不同的人，再决定你想和谁真正见一面。</text>
          </view>
          <view class="meet-feed">
            <view wx:for="{{goodPeopleRows}}" wx:key="id" class="meet-row">
              <view
                wx:if="{{item.left}}"
                class="meet-person-card meet-person-card--left meet-person-card--{{item.left.tone}} meet-person-card--offset-{{item.left.offset}}"
                data-person-id="{{item.left.personId}}"
                bindtap="openPerson"
              >
                <text class="meet-person-card__name">{{item.left.name}}</text>
                <text class="meet-person-card__line">{{item.left.line}}</text>
                <text class="meet-person-card__title">{{item.left.title}}</text>
                <text class="meet-person-card__quote">{{item.left.quote}}</text>
              </view>

              <view
                wx:if="{{item.right}}"
                class="meet-person-card meet-person-card--right meet-person-card--{{item.right.tone}} meet-person-card--offset-{{item.right.offset}}"
                data-person-id="{{item.right.personId}}"
                bindtap="openPerson"
              >
                <text class="meet-person-card__name">{{item.right.name}}</text>
                <text class="meet-person-card__line">{{item.right.line}}</text>
                <text class="meet-person-card__title">{{item.right.title}}</text>
                <text class="meet-person-card__quote">{{item.right.quote}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>
