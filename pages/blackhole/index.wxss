.immersive-scene {
  position: relative;
  overflow: hidden;
  height: 100vh;
  background:
      radial-gradient(circle at 72% 18%, rgba(241, 231, 121, 0.18), transparent 18%),
      radial-gradient(circle at 30% 28%, rgba(221, 160, 134, 0.14), transparent 26%),
      linear-gradient(180deg, #020202 0, #080808 58%, #0c0c0c 100%);
  animation: dreamBg 18s ease-in-out infinite alternate;
}

.immersive-scene__veil {
  position: absolute;
  left: 0;
  right: 0;
  pointer-events: none;
  z-index: 2;
}

.immersive-scene__veil--top {
  top: 0;
  height: 320rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0));
}

.immersive-scene__veil--bottom {
  bottom: 0;
  height: 360rpx;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.92), rgba(0, 0, 0, 0));
}

.immersive-scene__grain {
  position: absolute;
  inset: 0;
  opacity: 0.14;
  pointer-events: none;
  background-image:
    radial-gradient(rgba(255, 255, 255, 0.08) 0.7rpx, transparent 0.7rpx);
  background-size: 12rpx 12rpx;
  mask-image: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.7) 24%, rgba(0, 0, 0, 0.9));
}

.immersive-scene::before,
.immersive-scene::after {
  content: '';
  position: absolute;
  inset: -10%;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(90rpx);
  opacity: 0.48;
}

.immersive-scene__veil--bottom::after {
  content: '';
  position: absolute;
  left: -12%;
  right: -12%;
  bottom: -10%;
  height: 260rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, rgba(246, 208, 176, 0.14), rgba(232, 169, 143, 0.06) 36%, rgba(0, 0, 0, 0) 74%);
  filter: blur(56rpx);
  opacity: 0.3;
  animation: bottomBreath 18s ease-in-out infinite;
}

.immersive-scene::before {
  background:
    radial-gradient(circle at 24% 34%, rgba(255, 210, 186, 0.14), transparent 28%),
    radial-gradient(circle at 74% 28%, rgba(244, 232, 132, 0.14), transparent 24%);
  animation: dreamMistA 22s ease-in-out infinite;
}

.immersive-scene::after {
  background:
    radial-gradient(circle at 64% 72%, rgba(232, 169, 143, 0.12), transparent 24%),
    radial-gradient(circle at 42% 54%, rgba(255, 244, 215, 0.08), transparent 22%);
  animation: dreamMistB 26s ease-in-out infinite;
}

.immersive-back {
  position: absolute;
  top: calc(44px + env(safe-area-inset-top));
  left: 32rpx;
  z-index: 5;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: rgba(243, 241, 231, 0.68);
  font-size: 22rpx;
  backdrop-filter: blur(18rpx);
}

.immersive-scene__ambient {
  position: absolute;
  z-index: 1;
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.42;
  pointer-events: none;
}

.immersive-scene__ambient--a {
  top: 14%;
  left: -8%;
  width: 420rpx;
  height: 420rpx;
  background: rgba(255, 219, 182, 0.18);
  animation: dreamMistA 20s ease-in-out infinite;
}

.immersive-scene__ambient--b {
  top: 20%;
  right: -10%;
  width: 460rpx;
  height: 460rpx;
  background: rgba(244, 232, 132, 0.16);
  animation: dreamMistB 24s ease-in-out infinite;
}

.immersive-scene__ambient--c {
  bottom: 8%;
  left: 24%;
  width: 520rpx;
  height: 360rpx;
  background: rgba(232, 169, 143, 0.12);
  animation: dreamMistC 18s ease-in-out infinite;
}

.immersive-meteor {
  position: absolute;
  z-index: 2;
  width: 280rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 248, 224, 0.7), rgba(255, 212, 186, 0));
  filter: blur(10rpx);
  opacity: 0;
  transform: rotate(18deg);
  pointer-events: none;
}

.immersive-meteor--1 {
  top: 18%;
  left: 8%;
  animation: meteorFall 7.2s ease-in-out infinite;
}

.immersive-meteor--2 {
  top: 34%;
  right: 10%;
  width: 220rpx;
  animation: meteorFall 8.8s ease-in-out infinite 1.8s;
}

.immersive-meteor--3 {
  top: 52%;
  left: 26%;
  width: 300rpx;
  animation: meteorFall 9.6s ease-in-out infinite 3.4s;
}

.immersive-meteor--4 {
  top: 62%;
  right: 22%;
  width: 200rpx;
  animation: meteorFall 8.4s ease-in-out infinite 5s;
}

.immersive-meteor--5 {
  top: 26%;
  left: 46%;
  width: 180rpx;
  animation: meteorFall 10.4s ease-in-out infinite 6.6s;
}

.immersive-copy {
  position: absolute;
  z-index: 5;
  left: 50%;
  bottom: 240rpx;
  width: 680rpx;
  transform: translateX(-50%);
  min-height: 160rpx;
  text-align: center;
}

.immersive-copy__title,
.immersive-copy__shadow {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0;
}

.immersive-copy__title {
  color: rgba(255, 248, 239, 0.86);
  font-size: 46rpx;
  line-height: 1.38;
  letter-spacing: -1rpx;
  font-weight: 500;
  text-shadow:
    0 0 14rpx rgba(255, 236, 208, 0.1),
    0 8rpx 24rpx rgba(0, 0, 0, 0.22);
}

.immersive-copy__shadow {
  color: rgba(255, 247, 236, 0.16);
  text-shadow:
    0 0 24rpx rgba(255, 244, 230, 0.16),
    0 0 40rpx rgba(255, 244, 230, 0.08);
}

.immersive-copy__line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  white-space: nowrap;
}

.immersive-copy__line--en {
  letter-spacing: 0;
}

.immersive-copy__glyph {
  display: inline-block;
  transform-origin: center bottom;
  animation: immersiveGlyphRipple 5.6s ease-in-out infinite;
}

.immersive-copy__glyph--space {
  width: 16rpx;
}

.immersive-copy__title--cn {
  animation: immersiveTitleDriftCn 16s ease-in-out infinite;
}

.immersive-copy__shadow--cn {
  animation: immersiveShadowDriftCn 16s ease-in-out infinite;
}

.immersive-copy__title--en {
  font-size: 28rpx;
  font-weight: 400;
  animation: immersiveTitleDriftEn 20s ease-in-out infinite;
}

.immersive-copy__shadow--en {
  font-size: 28rpx;
  font-weight: 400;
  animation: immersiveShadowDriftEn 20s ease-in-out infinite;
}

.immersive-minibar {
  position: absolute;
  right: 32rpx;
  bottom: calc(44rpx + env(safe-area-inset-bottom));
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.immersive-minibar__status,
.immersive-minibar__end {
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
  backdrop-filter: blur(18rpx);
}

@keyframes dreamBg {
  0% {
    background:
      radial-gradient(circle at 72% 18%, rgba(241, 231, 121, 0.16), transparent 18%),
      radial-gradient(circle at 30% 28%, rgba(221, 160, 134, 0.12), transparent 26%),
      linear-gradient(180deg, #020202 0, #080808 58%, #0c0c0c 100%);
  }
  100% {
    background:
      radial-gradient(circle at 68% 20%, rgba(244, 232, 132, 0.2), transparent 20%),
      radial-gradient(circle at 34% 30%, rgba(232, 169, 143, 0.16), transparent 28%),
      linear-gradient(180deg, #030303 0, #090909 58%, #0d0d0d 100%);
  }
}

@keyframes presenceEntryFade {
  0% {
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  100% {
    opacity: 1;
  }
}

@keyframes requestPulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(0.88);
    opacity: 0.72;
  }
}

@keyframes dreamMistA {
  0%,
  100% {
    transform: translate3d(-2%, -1%, 0) scale(0.98);
    opacity: 0.34;
  }
  50% {
    transform: translate3d(3%, 2%, 0) scale(1.06);
    opacity: 0.52;
  }
}

@keyframes dreamMistB {
  0%,
  100% {
    transform: translate3d(1%, 0, 0) scale(1);
    opacity: 0.28;
  }
  50% {
    transform: translate3d(-3%, -2%, 0) scale(1.08);
    opacity: 0.46;
  }
}

@keyframes dreamMistC {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(0.96);
    opacity: 0.24;
  }
  50% {
    transform: translate3d(4%, -2%, 0) scale(1.04);
    opacity: 0.4;
  }
}

@keyframes meteorFall {
  0% {
    opacity: 0;
    transform: translate3d(-40rpx, -30rpx, 0) rotate(18deg) scale(0.92);
  }
  18% {
    opacity: 0.42;
  }
  46% {
    opacity: 0.18;
    transform: translate3d(130rpx, 170rpx, 0) rotate(18deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate3d(160rpx, 210rpx, 0) rotate(18deg) scale(1.02);
  }
}

@keyframes bottomBreath {
  0%,
  100% {
    opacity: 0.24;
    transform: translate3d(0, 12rpx, 0) scaleX(0.94) scaleY(0.9);
  }
  50% {
    opacity: 0.48;
    transform: translate3d(0, -10rpx, 0) scaleX(1.07) scaleY(1.04);
  }
}

@keyframes immersiveTitleDriftCn {
  0%,
  100% {
    opacity: 0.08;
    transform: translateY(-50%) translate3d(0, 16rpx, 0) scaleX(0.972) scaleY(0.956) skewX(-4deg);
    letter-spacing: 5rpx;
  }
  12% {
    opacity: 0.22;
    transform: translateY(-50%) translate3d(0, 10rpx, 0) scaleX(1.022) scaleY(0.978) skewX(3deg);
    letter-spacing: 2rpx;
  }
  24% {
    opacity: 0.86;
    transform: translateY(-50%) translate3d(0, 1rpx, 0) scaleX(1.006) scaleY(1.018) skewX(-1deg);
    letter-spacing: -1rpx;
  }
  36% {
    opacity: 0.26;
    transform: translateY(-50%) translate3d(0, -6rpx, 0) scaleX(0.988) scaleY(0.984) skewX(-2.8deg);
    letter-spacing: 3rpx;
  }
  50%,
  88% {
    opacity: 0;
    transform: translateY(-50%) translate3d(0, -12rpx, 0) scaleX(1.03) scaleY(0.966) skewX(4deg);
    letter-spacing: 6rpx;
  }
}

@keyframes immersiveShadowDriftCn {
  0%,
  100% {
    opacity: 0.02;
    transform: translateY(-50%) translate3d(0, 22rpx, 0) scaleX(1.1) scaleY(0.9) skewX(-7deg);
  }
  16% {
    opacity: 0.14;
    transform: translateY(-50%) translate3d(0, 12rpx, 0) scaleX(0.92) scaleY(1.06) skewX(5deg);
  }
  24% {
    opacity: 0.22;
    transform: translateY(-50%) translate3d(0, 2rpx, 0) scaleX(1.08) scaleY(0.96) skewX(-2deg);
  }
  50%,
  88% {
    opacity: 0;
    transform: translateY(-50%) translate3d(0, -14rpx, 0) scaleX(1.12) scaleY(0.9) skewX(7deg);
  }
}

@keyframes immersiveTitleDriftEn {
  0%,
  44% {
    opacity: 0;
    transform: translateY(-50%) translate3d(0, 18rpx, 0) scaleX(0.968) scaleY(0.95) skewX(-5deg);
    letter-spacing: 18rpx;
  }
  56% {
    opacity: 0.22;
    transform: translateY(-50%) translate3d(0, 11rpx, 0) scaleX(1.032) scaleY(0.972) skewX(4deg);
    letter-spacing: 14rpx;
  }
  68% {
    opacity: 0.84;
    transform: translateY(-50%) translate3d(0, 2rpx, 0) scaleX(1.01) scaleY(1.02) skewX(-1.5deg);
    letter-spacing: 8rpx;
  }
  78% {
    opacity: 0.42;
    transform: translateY(-50%) translate3d(0, -3rpx, 0) scaleX(0.986) scaleY(0.986) skewX(2.4deg);
    letter-spacing: 12rpx;
  }
  86% {
    opacity: 0.14;
    transform: translateY(-50%) translate3d(0, -8rpx, 0) scaleX(1.03) scaleY(0.972) skewX(-4deg);
    letter-spacing: 16rpx;
  }
  100% {
    opacity: 0;
    transform: translateY(-50%) translate3d(0, -14rpx, 0) scaleX(1.05) scaleY(0.958) skewX(5deg);
    letter-spacing: 20rpx;
  }
}

@keyframes immersiveShadowDriftEn {
  0%,
  44% {
    opacity: 0;
    transform: translateY(-50%) translate3d(0, 24rpx, 0) scaleX(1.14) scaleY(0.88) skewX(-8deg);
  }
  56% {
    opacity: 0.14;
    transform: translateY(-50%) translate3d(0, 14rpx, 0) scaleX(0.9) scaleY(1.08) skewX(7deg);
  }
  68% {
    opacity: 0.24;
    transform: translateY(-50%) translate3d(0, 4rpx, 0) scaleX(1.1) scaleY(0.95) skewX(-2deg);
  }
  78% {
    opacity: 0.14;
    transform: translateY(-50%) translate3d(0, -3rpx, 0) scaleX(0.94) scaleY(1.03) skewX(4deg);
  }
  100% {
    opacity: 0;
    transform: translateY(-50%) translate3d(0, -16rpx, 0) scaleX(1.16) scaleY(0.88) skewX(8deg);
  }
}

@keyframes immersiveGlyphRipple {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scaleX(1) scaleY(1) skewX(0deg);
  }
  25% {
    transform: translate3d(0, 2rpx, 0) scaleX(0.92) scaleY(1.08) skewX(-6deg);
  }
  50% {
    transform: translate3d(0, -1rpx, 0) scaleX(1.06) scaleY(0.94) skewX(4deg);
  }
  75% {
    transform: translate3d(0, 1rpx, 0) scaleX(0.97) scaleY(1.03) skewX(-3deg);
  }
}

@keyframes dialogDetailIn {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes sheetFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes sheetSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes cardFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes cardSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

