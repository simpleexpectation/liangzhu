.blackhole-page {
  position: relative;
  min-height: 100vh;
  background: #000000;
  transition: opacity 220ms ease, transform 220ms ease;
}

.presence-shell {
  position: relative;
  min-height: 100vh;
  padding: 0 32rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow: hidden;
}

.presence-shell--light {
  background:
    radial-gradient(circle at 72% 18%, rgba(241, 231, 121, 0.18), transparent 18%),
    radial-gradient(circle at 30% 28%, rgba(221, 160, 134, 0.14), transparent 26%),
    linear-gradient(180deg, #020202 0, #080808 58%, #0c0c0c 100%);
}

.presence-shell__glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(20rpx);
}

.presence-shell__glow--a {
  top: 120rpx;
  right: 24rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(244, 232, 132, 0.32), rgba(244, 232, 132, 0));
}

.presence-shell__glow--b {
  top: 160rpx;
  left: -40rpx;
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(232, 169, 143, 0.14), rgba(232, 169, 143, 0));
}

.presence-before {
  position: relative;
  z-index: 2;
}

.presence-spaces {
  position: relative;
  z-index: 2;
}

.presence-section-swiper {
  position: relative;
  z-index: 2;
  height: calc(100vh - 180rpx);
}

.presence-section-scroll {
  height: 100%;
  box-sizing: border-box;
}

.presence-section-scroll--single {
  margin-top: 8rpx;
}

.presence-top-offset {
  width: 100%;
}

.presence-subtabs {
  margin-top: 0;
  display: flex;
  align-items: flex-start;
  gap: 34rpx;
  position: relative;
  z-index: 3;
}

.presence-subtabs--single {
  gap: 0;
}

.presence-subtabs__item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.presence-subtabs__eyebrow {
  color: rgba(243, 241, 231, 0.34);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.presence-subtabs__label {
  color: rgba(243, 241, 231, 0.22);
  font-size: 76rpx;
  line-height: 0.9;
  letter-spacing: -3rpx;
  font-weight: 600;
}

.presence-subtabs__item--active .presence-subtabs__eyebrow {
  color: rgba(243, 241, 231, 0.58);
}

.presence-subtabs__item--active .presence-subtabs__label {
  color: #f3f1e7;
}

.places-banner {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  position: relative;
  z-index: 3;
}

.places-banner__eyebrow {
  color: rgba(243, 241, 231, 0.34);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  line-height: 1;
  text-transform: uppercase;
}

.places-banner__label {
  color: #f3f1e7;
  font-size: 80rpx;
  line-height: 0.92;
  letter-spacing: -3rpx;
  font-weight: 700;
}

.venue-page-head--presence {
  display: block;
  margin-top: 14rpx;
}

.venue-page-head__copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(243, 241, 231, 0.52);
  font-size: 24rpx;
  line-height: 1.6;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 44rpx;
  margin-top: 28rpx;
  padding-bottom: 40rpx;
}

.venue-stage {
  position: relative;
  z-index: 2;
}

.venue-stage__head {
  display: flex;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.venue-stage__caption {
  width: 340rpx;
  color: rgba(243, 241, 231, 0.8);
  font-size: 22rpx;
  line-height: 1.35;
}

.venue-stage__card {
  position: relative;
  overflow: hidden;
  min-height: 650rpx;
  border-radius: 58rpx;
  box-shadow:
    0 30rpx 90rpx rgba(0, 0, 0, 0.28),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.06);
}

.venue-stage__card--0 {
  background:
    radial-gradient(circle at 74% 18%, rgba(243, 232, 130, 0.72), transparent 20%),
    linear-gradient(180deg, #d6a18d 0%, #d8a38d 100%);
}

.venue-stage__card--1 {
  background:
    radial-gradient(circle at 74% 16%, rgba(212, 234, 165, 0.62), transparent 20%),
    linear-gradient(180deg, #d4c09d 0%, #c7d5a1 100%);
}

.venue-stage__card--2 {
  background:
    radial-gradient(circle at 24% 18%, rgba(208, 228, 240, 0.42), transparent 20%),
    linear-gradient(180deg, #c7c1ca 0%, #ddd1c3 100%);
}

.venue-stage__glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 72% 18%, rgba(255, 255, 255, 0.18), transparent 26%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
}

.venue-stage__body {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 2;
  padding: 28rpx 28rpx 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, rgba(19, 16, 15, 0.08), rgba(19, 16, 15, 0.18));
  backdrop-filter: blur(18rpx);
}

.venue-stage__eyebrow {
  display: block;
  color: rgba(23, 19, 18, 0.48);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.venue-stage__title {
  display: block;
  margin-top: 14rpx;
  color: #171312;
  font-size: 58rpx;
  line-height: 1.02;
  font-weight: 600;
}

.venue-stage__copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(23, 19, 18, 0.66);
  font-size: 24rpx;
  line-height: 1.5;
}

.venue-stage__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.venue-stage__meta-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(17, 14, 13, 0.14);
  color: rgba(23, 19, 18, 0.74);
  font-size: 22rpx;
}

.venue-recommend-entry {
  position: relative;
  overflow: hidden;
  margin-top: 8rpx;
  padding: 30rpx 28rpx 28rpx;
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 82% 18%, rgba(243, 232, 130, 0.18), transparent 20%),
    radial-gradient(circle at 20% 80%, rgba(210, 226, 255, 0.14), transparent 22%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.03));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 24rpx 64rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(18rpx);
}

.venue-recommend-entry__glow {
  position: absolute;
  top: -28rpx;
  right: 16rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(243, 232, 130, 0.16), rgba(243, 232, 130, 0));
  filter: blur(18rpx);
}

.venue-recommend-entry__eyebrow,
.venue-recommend-entry__title,
.venue-recommend-entry__copy,
.venue-recommend-entry__footer {
  position: relative;
  z-index: 1;
}

.venue-recommend-entry__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.4);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.venue-recommend-entry__title {
  display: block;
  margin-top: 12rpx;
  color: #f3f1e7;
  font-size: 42rpx;
  line-height: 1.04;
  font-weight: 600;
}

.venue-recommend-entry__copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.7);
  font-size: 24rpx;
  line-height: 1.65;
}

.venue-recommend-entry__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.venue-recommend-entry__meta {
  color: rgba(243, 241, 231, 0.46);
  font-size: 20rpx;
}

.venue-recommend-entry__action {
  min-width: 164rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  color: #141210;
  font-size: 24rpx;
  font-weight: 600;
}

.good-people-shell {
  position: relative;
  z-index: 2;
}

.good-people-head {
  margin-top: 12rpx;
}

.meet-feed {
  margin-top: 18rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.meet-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  column-gap: 18rpx;
  align-items: start;
  margin-bottom: 18rpx;
}

.meet-person-card {
  min-height: 298rpx;
  padding: 22rpx 20rpx 22rpx;
  border-radius: 28rpx;
  box-shadow:
    0 18rpx 42rpx rgba(0, 0, 0, 0.12),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(14rpx);
}

.meet-person-card--left.meet-person-card--offset-0 {
  transform: translateY(0) rotate(-0.8deg);
}

.meet-person-card--right.meet-person-card--offset-1 {
  transform: translateY(16rpx) rotate(0.7deg);
}

.meet-person-card--left.meet-person-card--offset-2 {
  transform: translateY(-6rpx) rotate(0.4deg);
}

.meet-person-card--right.meet-person-card--offset-3 {
  transform: translateY(10rpx) rotate(-0.5deg);
}

.meet-person-card--mist {
  background:
    radial-gradient(circle at 18% 16%, rgba(248, 238, 221, 0.46), transparent 28%),
    radial-gradient(circle at 82% 84%, rgba(206, 220, 241, 0.36), transparent 30%),
    linear-gradient(180deg, rgba(234, 229, 222, 0.94), rgba(208, 216, 226, 0.92));
}

.meet-person-card--peach {
  background:
    radial-gradient(circle at 22% 18%, rgba(255, 201, 176, 0.44), transparent 28%),
    radial-gradient(circle at 80% 78%, rgba(255, 235, 212, 0.24), transparent 24%),
    linear-gradient(180deg, rgba(244, 213, 196, 0.94), rgba(229, 191, 171, 0.92));
}

.meet-person-card--sand {
  background:
    radial-gradient(circle at 78% 82%, rgba(244, 223, 187, 0.38), transparent 30%),
    radial-gradient(circle at 18% 18%, rgba(253, 245, 218, 0.26), transparent 22%),
    linear-gradient(180deg, rgba(236, 221, 189, 0.94), rgba(220, 202, 165, 0.92));
}

.meet-person-card--sky {
  background:
    radial-gradient(circle at 80% 18%, rgba(196, 218, 255, 0.42), transparent 28%),
    radial-gradient(circle at 18% 82%, rgba(229, 239, 255, 0.22), transparent 24%),
    linear-gradient(180deg, rgba(208, 221, 238, 0.94), rgba(185, 203, 226, 0.92));
}

.meet-person-card--rose {
  background:
    radial-gradient(circle at 20% 82%, rgba(245, 195, 208, 0.38), transparent 28%),
    radial-gradient(circle at 82% 18%, rgba(255, 236, 241, 0.22), transparent 24%),
    linear-gradient(180deg, rgba(235, 211, 219, 0.94), rgba(222, 191, 202, 0.92));
}

.meet-person-card--ivory {
  background:
    radial-gradient(circle at 82% 18%, rgba(250, 238, 210, 0.32), transparent 24%),
    radial-gradient(circle at 18% 86%, rgba(233, 221, 196, 0.18), transparent 26%),
    linear-gradient(180deg, rgba(233, 227, 214, 0.94), rgba(217, 208, 188, 0.92));
}

.meet-person-card__title {
  display: block;
  margin-top: 22rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.22;
  letter-spacing: -0.8rpx;
  font-weight: 700;
}

.meet-person-card__name {
  display: block;
  margin-top: 0;
  color: #111111;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
}

.meet-person-card__line {
  display: block;
  margin-top: 8rpx;
  color: rgba(17, 17, 17, 0.58);
  font-size: 20rpx;
  line-height: 1.45;
}

.meet-person-card__quote {
  display: block;
  margin-top: 16rpx;
  color: rgba(17, 17, 17, 0.46);
  font-size: 18rpx;
  line-height: 1.5;
}

.presence-conversation-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 26rpx;
  padding-bottom: 28rpx;
}

.presence-dialog {
  position: relative;
  overflow: hidden;
  min-height: 720rpx;
  padding: 28rpx;
  box-sizing: border-box;
  border-radius: 40rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow:
    0 32rpx 96rpx rgba(0, 0, 0, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(22rpx);
  z-index: 2;
}

.presence-subtabs__item,
.venue-recommend-entry,
.presence-mini-card__button,
.presence-action-dock__ghost,
.presence-action-dock__cta {
  position: relative;
  z-index: 4;
}

.presence-dialog--active {
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow:
    0 28rpx 74rpx rgba(0, 0, 0, 0.24),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.presence-dialog--hero {
  border-radius: 42rpx;
}

.presence-dialog--0 {
  background:
    radial-gradient(circle at 72% 22%, rgba(250, 234, 136, 0.4), transparent 22%),
    radial-gradient(circle at 28% 76%, rgba(238, 193, 162, 0.3), transparent 28%),
    linear-gradient(180deg, rgba(188, 202, 210, 0.52), rgba(230, 203, 184, 0.38) 74%, rgba(191, 194, 177, 0.32) 100%);
}

.presence-dialog--1 {
  background:
    radial-gradient(circle at 76% 22%, rgba(245, 240, 166, 0.34), transparent 22%),
    radial-gradient(circle at 22% 74%, rgba(178, 220, 214, 0.3), transparent 28%),
    linear-gradient(180deg, rgba(168, 205, 196, 0.52), rgba(209, 224, 180, 0.36) 66%, rgba(224, 204, 176, 0.3) 100%);
}

.presence-dialog--2 {
  background:
    radial-gradient(circle at 72% 20%, rgba(255, 214, 149, 0.34), transparent 22%),
    radial-gradient(circle at 24% 78%, rgba(241, 155, 103, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(110, 102, 84, 0.5), rgba(196, 118, 69, 0.38) 64%, rgba(235, 180, 110, 0.28) 100%);
}

.presence-dialog--3 {
  background:
    radial-gradient(circle at 76% 22%, rgba(255, 238, 163, 0.34), transparent 22%),
    radial-gradient(circle at 20% 76%, rgba(179, 191, 255, 0.3), transparent 26%),
    linear-gradient(180deg, rgba(152, 169, 226, 0.48), rgba(191, 177, 229, 0.34) 58%, rgba(242, 205, 174, 0.28) 100%);
}

.presence-dialog--4 {
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 216, 194, 0.18), transparent 22%),
    radial-gradient(circle at 74% 76%, rgba(190, 227, 204, 0.13), transparent 28%),
    linear-gradient(180deg, rgba(207, 214, 203, 0.3), rgba(223, 230, 187, 0.24) 56%, rgba(240, 209, 191, 0.22) 100%);
}

.presence-dialog--5 {
  background:
    radial-gradient(circle at 74% 20%, rgba(255, 238, 193, 0.18), transparent 22%),
    radial-gradient(circle at 22% 78%, rgba(199, 214, 255, 0.13), transparent 26%),
    linear-gradient(180deg, rgba(207, 209, 227, 0.3), rgba(227, 213, 214, 0.26) 62%, rgba(240, 223, 183, 0.22) 100%);
}

.presence-dialog--6 {
  background:
    radial-gradient(circle at 68% 20%, rgba(240, 225, 170, 0.15), transparent 20%),
    radial-gradient(circle at 26% 76%, rgba(181, 222, 255, 0.13), transparent 26%),
    linear-gradient(180deg, rgba(125, 143, 135, 0.28), rgba(167, 184, 177, 0.24) 52%, rgba(231, 208, 184, 0.22) 100%);
}

.presence-dialog--7 {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 221, 201, 0.15), transparent 20%),
    radial-gradient(circle at 78% 76%, rgba(214, 239, 195, 0.1), transparent 24%),
    linear-gradient(180deg, rgba(217, 206, 197, 0.28), rgba(233, 220, 204, 0.24) 62%, rgba(217, 235, 185, 0.2) 100%);
}

.presence-dialog--8 {
  background:
    radial-gradient(circle at 72% 20%, rgba(218, 236, 255, 0.15), transparent 22%),
    radial-gradient(circle at 20% 78%, rgba(255, 232, 189, 0.1), transparent 26%),
    linear-gradient(180deg, rgba(216, 211, 223, 0.28), rgba(232, 226, 213, 0.24) 66%, rgba(203, 224, 239, 0.2) 100%);
}

.presence-dialog__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(32rpx);
  pointer-events: none;
}

.presence-dialog__mist--a {
  top: -28rpx;
  right: 18rpx;
  width: 280rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.12);
}

.presence-dialog__mist--b {
  left: 36rpx;
  bottom: 36rpx;
  width: 340rpx;
  height: 220rpx;
  background: rgba(255, 214, 190, 0.1);
}

.presence-dialog__head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.presence-dialog__role-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.presence-dialog__role {
  display: inline-flex;
  color: rgba(243, 241, 231, 0.44);
  font-size: 20rpx;
}

.presence-dialog__ephemeral {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  color: rgba(243, 241, 231, 0.52);
  font-size: 18rpx;
  letter-spacing: 0.04em;
}

.presence-dialog__title {
  display: block;
  color: #f3f1e7;
  font-size: 54rpx;
  line-height: 1.18;
  letter-spacing: -1.8rpx;
  font-weight: 600;
}

.presence-dialog__meta {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.74);
  font-size: 28rpx;
  line-height: 1.5;
}

.presence-dialog__date {
  text-align: right;
}

.presence-dialog__month {
  display: block;
  color: rgba(243, 241, 231, 0.78);
  font-size: 22rpx;
}

.presence-dialog__day {
  display: block;
  margin-top: 2rpx;
  color: #f3f1e7;
  font-size: 108rpx;
  line-height: 0.9;
  letter-spacing: -4rpx;
  font-weight: 300;
}

.presence-dialog__body {
  position: relative;
  z-index: 1;
  margin-top: 332rpx;
}

.presence-dialog__status {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.presence-dialog__pill {
  flex-shrink: 0;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.presence-dialog__pill--confirmed {
  background: rgba(255, 244, 236, 0.14);
  color: #f3f1e7;
}

.presence-dialog__pill--pending {
  background: rgba(239, 187, 158, 0.18);
  color: #ffd7c1;
}

.presence-dialog__pill--declined {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(243, 241, 231, 0.62);
}

.presence-dialog__pill--recap {
  background: rgba(255, 244, 236, 0.14);
  color: #f3f1e7;
}

.presence-dialog__hint {
  color: rgba(243, 241, 231, 0.74);
  font-size: 22rpx;
  line-height: 1.5;
  max-width: 430rpx;
}

.presence-dialog__auto {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: rgba(243, 241, 231, 0.56);
  font-size: 20rpx;
}

.presence-dialog__chevron-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.presence-dialog__chevron {
  color: rgba(243, 241, 231, 0.24);
  font-size: 28rpx;
  line-height: 1;
  transform: rotate(0deg);
  transition: transform 180ms ease, color 180ms ease, opacity 180ms ease;
}

.presence-dialog__chevron--active {
  color: rgba(243, 241, 231, 0.46);
  transform: rotate(180deg);
}

.presence-dialog__detail {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  animation: dialogDetailIn 240ms ease;
}

.presence-action-dock {
  padding: 18rpx 18rpx 20rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 82% 18%, rgba(238, 228, 150, 0.1), transparent 24%),
    linear-gradient(180deg, rgba(130, 132, 113, 0.34), rgba(106, 104, 91, 0.28));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(16rpx);
}

.presence-dialog--0 .presence-action-dock {
  background:
    radial-gradient(circle at 82% 18%, rgba(238, 228, 150, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(146, 149, 129, 0.38), rgba(118, 114, 100, 0.3));
}

.presence-dialog--2 .presence-action-dock {
  background:
    radial-gradient(circle at 82% 18%, rgba(243, 216, 138, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(122, 103, 82, 0.36), rgba(112, 89, 70, 0.3));
}

.presence-dialog--3 .presence-action-dock {
  background:
    radial-gradient(circle at 82% 18%, rgba(241, 224, 149, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(133, 138, 121, 0.36), rgba(112, 109, 96, 0.3));
