<view class="page-shell person-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <nav-shell eyebrow="Profile" title="个人资料">
    <view class="person-nav">
      <view class="person-nav__back" bindtap="goBack">返回</view>
    </view>
  </nav-shell>

  <view class="person-hero">
    <view class="person-hero__glow person-hero__glow--a"></view>
    <view class="person-hero__glow person-hero__glow--b"></view>
    <view class="person-avatar">
      <text class="person-avatar__initial">{{person.initial}}</text>
    </view>
    <text class="person-name">{{person.name}}</text>
    <view class="person-bio-lines">
      <text class="person-bio-line">◈  {{person.bio}}</text>
      <text class="person-bio-line">⌖  {{person.location}}</text>
    </view>
    <view class="person-tags">
      <view wx:for="{{person.tags}}" wx:key="index" class="pill">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{statusCards.length}}" class="person-status">
    <view class="person-status__head">
      <text class="person-status__eyebrow">THOUGHTS</text>
      <text class="person-status__title">思考</text>
    </view>
    <view class="person-status__list">
      <view
        wx:for="{{statusCards}}"
        wx:key="id"
        class="person-status__card person-status__card--{{item.tone}}"
        data-thought-id="{{item.id}}"
        bindtap="openIdeaDetail"
      >
        <text class="person-status__card-title">{{item.title}}</text>
        <text class="person-status__card-copy">{{item.quote}}</text>
        <text class="person-status__card-meta">{{item.createdAt}}</text>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showThoughtDetail}}" class="thought-modal" bindtap="closeThoughtDetail">
  <view class="thought-modal__window {{thoughtDetailExpanded ? 'thought-modal__window--expanded' : ''}}" catchtap="">
    <scroll-view scroll-y="{{thoughtDetailExpanded}}" class="thought-modal__scroll {{thoughtDetailExpanded ? 'thought-modal__scroll--expanded' : ''}}">
      <view class="thought-modal__hero thought-modal__hero--{{selectedThought.tone}}">
        <text class="thought-modal__label">THOUGHT</text>
        <text class="thought-modal__title">{{selectedThought.title}}</text>
      </view>
      <view class="thought-modal__body">
        <text class="thought-modal__text {{thoughtDetailExpanded ? 'thought-modal__text--expanded' : ''}}">{{selectedThought.detailText}}</text>
        <view wx:if="{{selectedThought.canExpand && !thoughtDetailExpanded}}" class="thought-modal__expand" catchtap="expandThoughtDetail"></view>
      </view>
    </scroll-view>
  </view>
</view>
