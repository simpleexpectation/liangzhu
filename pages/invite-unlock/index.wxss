.invite-page {
  position: relative;
  overflow: hidden;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.invite-page__glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(120rpx);
  pointer-events: none;
  opacity: 0.6;
}

.invite-page__glow--a {
  top: 180rpx;
  right: -80rpx;
  width: 360rpx;
  height: 340rpx;
  background: rgba(245, 213, 147, 0.18);
}

.invite-page__glow--b {
  left: -70rpx;
  top: 780rpx;
  width: 280rpx;
  height: 240rpx;
  background: rgba(157, 171, 205, 0.14);
}

.detail-topbar {
  margin-bottom: 12rpx;
}

.detail-topbar__back {
  color: rgba(243, 241, 231, 0.78);
  font-size: 30rpx;
  line-height: 1.2;
}

.detail-section {
  margin-top: 18rpx;
}

.detail-section--invite {
  margin-top: 48rpx;
}

.detail-page__title {
  display: block;
  color: #f3f1e7;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1.04;
}

.detail-page__desc {
  display: block;
  margin-top: 18rpx;
  color: rgba(243, 241, 231, 0.5);
  font-size: 28rpx;
  line-height: 1.65;
}

.hero-card {
  margin-top: 28rpx;
  border-radius: 40rpx;
  padding: 34rpx 32rpx;
  min-height: 404rpx;
  background:
    radial-gradient(circle at 84% 18%, rgba(245, 233, 183, 0.38), transparent 28%),
    linear-gradient(145deg, #92a6b2 0%, #baa89f 42%, #d8be97 100%);
  box-shadow:
    0 20rpx 50rpx rgba(0, 0, 0, 0.32),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.14);
  box-sizing: border-box;
}

.hero-card--cobuild {
  background:
    radial-gradient(circle at 84% 18%, rgba(245, 233, 183, 0.28), transparent 28%),
    linear-gradient(145deg, #9ba8ba 0%, #9f8d80 44%, #c9b38d 100%);
}

.hero-card__eyebrow {
  display: block;
  color: rgba(255, 255, 255, 0.58);
  font-size: 18rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-card__title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 700;
}

.hero-card__price-row {
  display: flex;
  align-items: flex-end;
  margin-top: 18rpx;
}

.hero-card__currency {
  color: #ffffff;
  font-size: 30rpx;
  padding-bottom: 12rpx;
}

.hero-card__price {
  color: #ffffff;
  font-size: 94rpx;
  font-weight: 700;
  line-height: 0.92;
}

.hero-card__billing {
  color: rgba(255, 255, 255, 0.72);
  font-size: 28rpx;
  padding: 0 0 12rpx 10rpx;
}

.hero-card__copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-card__copy--wide {
  max-width: 560rpx;
  margin-top: 22rpx;
}

.hero-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 230rpx;
  height: 58rpx;
  padding: 0 22rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: rgba(97, 84, 68, 0.34);
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
}

.section-label {
  display: block;
  margin-top: 28rpx;
  margin-bottom: 14rpx;
  color: rgba(243, 241, 231, 0.42);
  font-size: 24rpx;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  border-radius: 28rpx;
  padding: 24rpx 26rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.benefit-item__icon {
  flex-shrink: 0;
  width: 34rpx;
  text-align: center;
  color: rgba(243, 241, 231, 0.88);
  font-size: 24rpx;
  line-height: 1.5;
}

.benefit-item__text {
  color: rgba(243, 241, 231, 0.82);
  font-size: 24rpx;
  line-height: 1.7;
}

.detail-actions {
  margin-top: 22rpx;
}

.primary-action,
.ghost-action {
  min-height: 96rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
}

.primary-action {
  background: #f0efe3;
  color: #171412;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-action {
  margin-top: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.86);
  font-size: 26rpx;
}

.code-card {
  margin-top: 26rpx;
  border-radius: 32rpx;
  padding: 28rpx 30rpx;
  background:
    radial-gradient(circle at 84% 18%, rgba(245, 233, 183, 0.3), transparent 28%),
    linear-gradient(145deg, #92a6b2 0%, #baa89f 42%, #d8be97 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.code-card__label {
  display: block;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
}

.code-card__value {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 62rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  font-weight: 700;
}

.code-card__button {
  min-width: 128rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(97, 84, 68, 0.36);
  color: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.board-card {
  margin-top: 18rpx;
  border-radius: 32rpx;
  padding: 28rpx 28rpx 30rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.board-card__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.5);
  font-size: 22rpx;
  line-height: 1.6;
}

.board-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 26rpx;
}

.board-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  text-align: center;
}

.board-node__orb {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.04);
}

.board-node__orb--active {
  border-color: rgba(242, 231, 173, 0.6);
  background:
    radial-gradient(circle at 50% 50%, rgba(245, 233, 183, 0.42), rgba(245, 233, 183, 0.08));
  box-shadow: 0 0 30rpx rgba(245, 233, 183, 0.18);
}

.board-node__status {
  color: rgba(243, 241, 231, 0.86);
  font-size: 24rpx;
}

.board-node__label {
  color: rgba(243, 241, 231, 0.48);
  font-size: 22rpx;
  line-height: 1.5;
}

.board-card__copy {
  display: block;
  margin-top: 22rpx;
  color: rgba(243, 241, 231, 0.74);
  font-size: 24rpx;
  line-height: 1.7;
}

.friend-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 8rpx;
}

.friend-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.friend-card__avatar {
  flex-shrink: 0;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #768399, #4f5767);
  color: rgba(255, 255, 255, 0.94);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 700;
}

.friend-card__copy {
  flex: 1;
}

.friend-card__name {
  display: block;
  color: rgba(243, 241, 231, 0.96);
  font-size: 28rpx;
  font-weight: 600;
}

.friend-card__note {
  display: block;
  margin-top: 8rpx;
  color: rgba(243, 241, 231, 0.5);
  font-size: 24rpx;
  line-height: 1.55;
}

.friend-card__cta {
  flex-shrink: 0;
  width: 132rpx;
  min-height: 100rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.4;
}

.primary-action--bottom {
  margin-top: 28rpx;
}
