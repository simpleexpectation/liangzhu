.starter-page {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 82% 10%, rgba(243, 229, 146, 0.14), transparent 22%),
    radial-gradient(circle at 18% 18%, rgba(156, 186, 212, 0.12), transparent 20%),
    radial-gradient(circle at 18% 72%, rgba(205, 165, 138, 0.1), transparent 22%),
    linear-gradient(180deg, #12100f 0%, #111012 30%, #14151a 58%, #0f1014 100%);
}

.starter-page::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 248, 235, 0.03), transparent 14%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.02), transparent 40%);
  pointer-events: none;
}

.starter-page__glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(90rpx);
  pointer-events: none;
  opacity: 0.6;
}

.starter-page__glow--a {
  width: 420rpx;
  height: 360rpx;
  top: 140rpx;
  right: -40rpx;
  background: rgba(243, 224, 144, 0.22);
}

.starter-page__glow--b {
  width: 340rpx;
  height: 280rpx;
  left: -30rpx;
  top: 460rpx;
  background: rgba(156, 186, 212, 0.16);
}

.starter-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.starter-nav__back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 250, 242, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #f3f1e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
}

.starter-nav__copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.starter-nav__title {
  color: #f3f1e7;
  font-size: 40rpx;
  font-weight: 600;
}

.starter-nav__sub {
  color: rgba(243, 241, 231, 0.48);
  font-size: 20rpx;
}

.starter-progress {
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.starter-progress__item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.starter-progress__dot {
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.starter-progress__dot--active {
  background: linear-gradient(90deg, #efe1bb, #ddb28f);
}

.starter-progress__label {
  color: rgba(243, 241, 231, 0.32);
  font-size: 18rpx;
  line-height: 1.4;
}

.starter-progress__label--active {
  color: rgba(243, 241, 231, 0.72);
}

.starter-section {
  margin-top: 34rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.starter-hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.starter-hero--card {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 82% 18%, rgba(242, 229, 151, 0.24), transparent 22%),
    radial-gradient(circle at 16% 84%, rgba(215, 147, 112, 0.14), transparent 24%),
    linear-gradient(180deg, rgba(133, 165, 183, 0.18) 0%, rgba(180, 151, 135, 0.16) 46%, rgba(229, 190, 121, 0.14) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.22);
}

.starter-hero__pills,
.identity-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 10rpx;
}

.starter-hero__pill,
.identity-card__chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.84);
  font-size: 20rpx;
  line-height: 1;
}

.starter-hero__eyebrow,
.section-head__eyebrow {
  color: rgba(243, 241, 231, 0.42);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.starter-hero__title,
.section-head__title {
  color: #f3f1e7;
  font-size: 58rpx;
  line-height: 1.06;
  letter-spacing: -1.8rpx;
  font-weight: 600;
}

.starter-hero__copy,
.section-head__copy {
  color: rgba(243, 241, 231, 0.76);
  font-size: 26rpx;
  line-height: 1.7;
}

.starter-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.upload-dropzone {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 80% 18%, rgba(245, 232, 132, 0.4), transparent 22%),
    radial-gradient(circle at 18% 80%, rgba(255, 234, 220, 0.16), transparent 26%),
    linear-gradient(180deg, rgba(226, 184, 160, 0.98), rgba(205, 161, 140, 0.98));
  box-shadow: 0 34rpx 96rpx rgba(0, 0, 0, 0.22);
}

.upload-dropzone__glow {
  position: absolute;
  right: 34rpx;
  top: 18rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(247, 236, 150, 0.72), rgba(247, 236, 150, 0));
  filter: blur(12rpx);
}

.upload-dropzone__head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.upload-dropzone__copy-block {
  width: 400rpx;
}

.upload-dropzone__title {
  color: #191211;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 600;
}

.upload-dropzone__action {
  flex-shrink: 0;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  color: #3a2520;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-dropzone__copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(25, 18, 17, 0.64);
  font-size: 22rpx;
  line-height: 1.6;
}

.upload-dropzone__tray {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  display: flex;
  gap: 14rpx;
}

.upload-dropzone__slot {
  width: 146rpx;
  height: 166rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: flex-end;
  padding: 18rpx;
  box-sizing: border-box;
}

.upload-dropzone__slot--filled {
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.upload-dropzone__slot--empty {
  align-items: center;
  justify-content: center;
  background: rgba(25, 18, 17, 0.1);
  border: 1rpx dashed rgba(25, 18, 17, 0.18);
}

.upload-dropzone__slot-label {
  color: rgba(25, 18, 17, 0.6);
  font-size: 20rpx;
}

.upload-dropzone__slot-plus {
  color: rgba(25, 18, 17, 0.42);
  font-size: 44rpx;
  line-height: 1;
}

.upload-card {
  overflow: hidden;
  min-height: 298rpx;
  border-radius: 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.035);
  box-shadow: 0 18rpx 52rpx rgba(0, 0, 0, 0.16);
}

.upload-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.upload-card--warm {
  background: rgba(255, 255, 255, 0.03);
}

.upload-card--mist {
  background: rgba(255, 255, 255, 0.03);
}

.upload-card--glow {
  background: rgba(255, 255, 255, 0.03);
}

.upload-card--selected {
  box-shadow: 0 0 0 2rpx rgba(244, 221, 175, 0.34);
}

.upload-card__image {
  position: relative;
  min-height: 230rpx;
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.upload-card--warm .upload-card__image {
  background:
    radial-gradient(circle at 78% 18%, rgba(246, 233, 138, 0.36), transparent 24%),
    linear-gradient(135deg, #bb8f84 0%, #d5ad9e 100%);
}

.upload-card--mist .upload-card__image {
  background:
    radial-gradient(circle at 24% 20%, rgba(246, 233, 138, 0.18), transparent 22%),
    linear-gradient(135deg, #8298af 0%, #b2aebb 100%);
}

.upload-card--glow .upload-card__image {
  background:
    radial-gradient(circle at 74% 18%, rgba(246, 233, 138, 0.3), transparent 24%),
    linear-gradient(135deg, #8b9478 0%, #cdb891 100%);
}

.upload-card__shine {
  position: absolute;
  right: 12rpx;
  top: 8rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(248, 237, 162, 0.54), rgba(248, 237, 162, 0));
  filter: blur(10rpx);
}

.upload-card__source {
  color: rgba(25, 18, 17, 0.46);
  font-size: 20rpx;
}

.upload-card__badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.34);
  color: #2b1f1b;
  font-size: 18rpx;
}

.upload-card__caption {
  margin-top: 14rpx;
  color: #191211;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 600;
}

.upload-card__footer {
  padding: 18rpx 22rpx 20rpx;
  background: rgba(10, 10, 10, 0.22);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.upload-card__state {
  color: rgba(243, 241, 231, 0.7);
  font-size: 22rpx;
}

.starter-note {
  padding: 28rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 84% 18%, rgba(243, 229, 146, 0.1), transparent 24%),
    linear-gradient(180deg, rgba(255, 253, 248, 0.08), rgba(255, 255, 255, 0.04));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.12);
}

.starter-note--soft {
  background:
    radial-gradient(circle at 86% 16%, rgba(243, 229, 146, 0.1), transparent 20%),
    linear-gradient(180deg, rgba(255, 253, 248, 0.08), rgba(255, 255, 255, 0.04));
}

.starter-note__title {
  display: block;
  color: #f3f1e7;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.starter-note__row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.starter-note__pill {
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.72);
  font-size: 24rpx;
}

.section-head {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.insight-list,
.topic-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.identity-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 82% 16%, rgba(243, 229, 146, 0.26), transparent 20%),
    radial-gradient(circle at 18% 86%, rgba(156, 186, 212, 0.14), transparent 24%),
    linear-gradient(180deg, rgba(123, 149, 168, 0.22) 0%, rgba(125, 116, 108, 0.2) 50%, rgba(206, 168, 134, 0.18) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.18);
}

.identity-card__glow {
  position: absolute;
  right: 30rpx;
  top: 10rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 236, 184, 0.22), rgba(245, 236, 184, 0));
  filter: blur(12rpx);
}

.identity-card__eyebrow,
.starter-picked__eyebrow {
  position: relative;
  z-index: 1;
  color: rgba(243, 241, 231, 0.44);
  font-size: 18rpx;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.identity-card__title,
.starter-picked__title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 18rpx;
  color: #f3f1e7;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 600;
}

.identity-card__copy,
.starter-picked__copy {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.72);
  font-size: 24rpx;
  line-height: 1.65;
}

.starter-picked {
  padding: 24rpx 28rpx;
  border-radius: 30rpx;
}

.insight-card {
  padding: 26rpx;
  border-radius: 30rpx;
}

.insight-card__title {
  display: block;
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
}

.insight-card__value {
  display: block;
  margin-top: 12rpx;
  color: #f3f1e7;
  font-size: 30rpx;
  line-height: 1.6;
}

.starter-topic {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 46rpx;
  min-height: 480rpx;
  display: flex;
  flex-direction: column;
}

.starter-topic--0 {
  background:
    radial-gradient(circle at 74% 18%, rgba(243, 229, 155, 0.34), transparent 22%),
    radial-gradient(circle at 28% 74%, rgba(215, 173, 147, 0.2), transparent 28%),
    linear-gradient(135deg, #92a6b2 0%, #baa89f 40%, #d8be97 100%);
}

.starter-topic--1 {
  background:
    radial-gradient(circle at 24% 18%, rgba(226, 197, 168, 0.26), transparent 22%),
    radial-gradient(circle at 78% 70%, rgba(210, 224, 170, 0.2), transparent 26%),
    linear-gradient(135deg, #b7b7cd 0%, #cdbdad 46%, #bcc8a2 100%);
}

.starter-topic--2 {
  background:
    radial-gradient(circle at 70% 22%, rgba(236, 226, 155, 0.26), transparent 22%),
    radial-gradient(circle at 24% 78%, rgba(179, 142, 118, 0.14), transparent 24%),
    linear-gradient(180deg, #506a67, #7b7f76 60%, #cbb19d 100%);
}

.starter-topic--selected {
  box-shadow:
    0 0 0 2rpx rgba(255, 255, 255, 0.22),
    0 18rpx 42rpx rgba(0, 0, 0, 0.24);
}

.starter-topic__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(32rpx);
}

.starter-topic__mist--a {
  top: -30rpx;
  right: 30rpx;
  width: 280rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.16);
}

.starter-topic__mist--b {
  left: 40rpx;
  bottom: 30rpx;
  width: 300rpx;
  height: 200rpx;
  background: rgba(255, 195, 157, 0.16);
}

.starter-topic__header,
.starter-topic__body,
.starter-topic__openers,
.starter-topic__footer {
  position: relative;
  z-index: 1;
}

.starter-topic__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.starter-topic__status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.starter-topic__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.82);
}

.starter-topic__status-label,
.starter-topic__seat {
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
}

.starter-topic__body {
  flex: 1;
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.starter-topic__depth {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.84);
  font-size: 18rpx;
  align-self: flex-start;
}

.starter-topic__title {
  display: block;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 46rpx;
  line-height: 1.12;
  font-weight: 600;
}

.starter-topic__meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  margin-top: 16rpx;
}

.starter-topic__initiator {
  color: rgba(255, 255, 255, 0.95);
  font-size: 24rpx;
  font-weight: 600;
}

.starter-topic__meta {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.starter-topic__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.starter-topic__pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.9);
  font-size: 20rpx;
}

.starter-topic__reason {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 1.7;
}

.starter-topic__openers {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.starter-topic__opener {
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  line-height: 1.6;
}

.starter-topic__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
}

.starter-topic__rules {
  flex: 1;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
  line-height: 1.5;
}

.starter-topic__select {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #111111;
  font-size: 22rpx;
  font-weight: 600;
}

.launch-card {
  padding: 28rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 88% 16%, rgba(243, 229, 146, 0.16), transparent 22%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.035));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.launch-card__title {
  display: block;
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
}

.launch-card__title--sub {
  margin-top: 24rpx;
}

.launch-card__topic {
  display: block;
  margin-top: 12rpx;
  color: #f3f1e7;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 600;
}

.launch-preview {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 84% 16%, rgba(243, 229, 146, 0.08), transparent 22%),
    rgba(255, 255, 255, 0.05);
}

.launch-preview__label {
  display: block;
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
  margin-bottom: 12rpx;
}

.launch-preview__copy {
  display: block;
  color: #f3f1e7;
  font-size: 26rpx;
  line-height: 1.7;
}

.launch-summary {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.045);
}

.launch-summary__copy {
  display: block;
  color: rgba(243, 241, 231, 0.68);
  font-size: 22rpx;
  line-height: 1.7;
}

.success-card {
  padding: 30rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 84% 14%, rgba(243, 229, 146, 0.16), transparent 20%),
    radial-gradient(circle at 16% 88%, rgba(156, 186, 212, 0.12), transparent 22%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.035));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.success-card__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.44);
  font-size: 18rpx;
  letter-spacing: 1.5rpx;
  text-transform: uppercase;
}

.success-card__title {
  display: block;
  margin-top: 16rpx;
  color: #f3f1e7;
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 600;
}

.success-card__status {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.76);
  font-size: 22rpx;
}

.success-card__section {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.success-card__label {
  display: block;
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
}

.success-card__copy {
  display: block;
  margin-top: 10rpx;
  color: #f3f1e7;
  font-size: 24rpx;
  line-height: 1.7;
}

.success-card__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.success-card__meta {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.success-card__meta-label {
  display: block;
  color: rgba(243, 241, 231, 0.42);
  font-size: 20rpx;
}

.success-card__meta-value {
  display: block;
  margin-top: 10rpx;
  color: #f3f1e7;
  font-size: 24rpx;
  line-height: 1.5;
}

.success-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.launch-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.launch-action {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  color: #f3f1e7;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.05);
}

.launch-action--primary {
  background: linear-gradient(135deg, #efe1bb, #ddb28f);
  color: #17130f;
  font-weight: 600;
}

.result-card {
  padding: 28rpx;
  border-radius: 34rpx;
}

.result-card__eyebrow {
  display: block;
  color: rgba(243, 241, 231, 0.38);
  font-size: 18rpx;
  text-transform: uppercase;
  letter-spacing: 1.4rpx;
}

.result-card__title {
  display: block;
  margin-top: 14rpx;
  color: #f3f1e7;
  font-size: 36rpx;
  font-weight: 600;
}

.result-card__copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(243, 241, 231, 0.7);
  font-size: 24rpx;
  line-height: 1.8;
}

.result-card__meta {
  display: block;
  margin-top: 16rpx;
  color: rgba(243, 241, 231, 0.46);
  font-size: 20rpx;
  line-height: 1.6;
}

.starter-footer {
  position: sticky;
  bottom: 26rpx;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 16rpx;
  margin-top: 36rpx;
}

.starter-footer__secondary,
.starter-footer__primary {
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.starter-footer__secondary {
  background: rgba(255, 255, 255, 0.05);
  color: #f3f1e7;
}

.starter-footer__primary {
  background: linear-gradient(135deg, #efe1bb, #ddb28f);
  color: #17130f;
  font-weight: 600;
}
