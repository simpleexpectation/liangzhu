<view class="page-shell starter-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <view class="starter-page__glow starter-page__glow--a"></view>
  <view class="starter-page__glow starter-page__glow--b"></view>

  <nav-shell eyebrow="Conversation flow">
    <view class="starter-nav">
      <view class="starter-nav__back" bindtap="goBack">‹</view>
      <view class="starter-nav__copy">
        <text class="starter-nav__title">从最近的表达开始</text>
        <text class="starter-nav__sub">
          {{entry === 'home' ? '首页轻露出进入' : '加号发起入口进入'}} · 从最近表达整理出一版可发起草稿
        </text>
      </view>
    </view>
  </nav-shell>

  <view class="starter-progress">
    <view wx:for="{{steps}}" wx:key="key" class="starter-progress__item">
      <view class="starter-progress__dot {{index <= currentStep ? 'starter-progress__dot--active' : ''}}"></view>
      <text class="starter-progress__label {{index === currentStep ? 'starter-progress__label--active' : ''}}">{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{currentStep === 0}}" class="starter-section">
    <view class="starter-hero starter-hero--card">
      <text class="starter-hero__eyebrow">向内探索，向外发现</text>
      <text class="starter-hero__title">先放进一点最近的你</text>
      <text class="starter-hero__copy">这里不是上传资料，而是让系统先接住你最近的表达，替你长出第一张对话卡的草稿。</text>
      <view class="starter-hero__pills">
        <text class="starter-hero__pill">最近状态</text>
        <text class="starter-hero__pill">一句想法</text>
        <text class="starter-hero__pill">一张截图</text>
      </view>
    </view>

    <view class="upload-dropzone">
      <view class="upload-dropzone__glow"></view>
      <view class="upload-dropzone__head">
        <view class="upload-dropzone__copy-block">
          <text class="upload-dropzone__title">上传最近 3 张表达</text>
          <text class="upload-dropzone__copy">朋友圈、Bonjour、小红书、备忘录都可以。先放 1 到 2 张也没关系。</text>
        </view>
        <text class="upload-dropzone__action">从相册选择</text>
      </view>
      <view class="upload-dropzone__tray">
        <view class="upload-dropzone__slot upload-dropzone__slot--filled">
          <text class="upload-dropzone__slot-label">最近状态</text>
        </view>
        <view class="upload-dropzone__slot upload-dropzone__slot--filled">
          <text class="upload-dropzone__slot-label">一张截图</text>
        </view>
        <view class="upload-dropzone__slot upload-dropzone__slot--empty">
          <text class="upload-dropzone__slot-plus">+</text>
        </view>
      </view>
    </view>

    <view class="starter-note starter-note--soft">
      <text class="starter-note__title">接下来不会让你填很多东西</text>
      <view class="starter-note__row">
        <text class="starter-note__pill">先整理最近线索</text>
        <text class="starter-note__pill">再长成一张卡</text>
        <text class="starter-note__pill">最后只定时间和地点</text>
      </view>
    </view>
  </view>

  <view wx:if="{{currentStep === 1}}" class="starter-section">
    <view class="section-head">
      <text class="section-head__eyebrow">此刻的你</text>
      <text class="section-head__title">这一页先长成“最近的你”</text>
      <text class="section-head__copy">不是给你下判断，而是先把最近的状态、想法和表达倾向，整理成一张可以继续往前走的卡。</text>
    </view>

    <view class="identity-card">
      <view class="identity-card__glow"></view>
      <text class="identity-card__eyebrow">Recent self card</text>
      <text class="identity-card__title">最近的你，像是在慢慢进入一个新的生活阶段。</text>
      <text class="identity-card__copy">你在重新适应一个人和城市相处的节奏，也更在意什么样的空间、什么样的人，会让自己感觉靠近。</text>
      <view class="identity-card__chips">
        <text class="identity-card__chip">新城市</text>
        <text class="identity-card__chip">独处</text>
        <text class="identity-card__chip">散步</text>
        <text class="identity-card__chip">节奏调整</text>
        <text class="identity-card__chip">空间感</text>
      </view>
    </view>

    <view class="insight-list">
      <view wx:for="{{insightCards}}" wx:key="title" class="insight-card glass-panel">
        <text class="insight-card__title">{{item.title}}</text>
        <text class="insight-card__value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{currentStep === 2}}" class="starter-section">
    <view class="section-head">
      <text class="section-head__eyebrow">适合开启的话题</text>
      <text class="section-head__title">这些线索，已经开始长成对话卡</text>
      <text class="section-head__copy">这里不再是建议列表，而是几张已经接近成品的发起卡。你只需要选一张最像现在自己的。</text>
    </view>

    <view class="starter-picked glass-panel">
      <text class="starter-picked__eyebrow">当前方向</text>
      <text class="starter-picked__title">{{selectedTopicTitle}}</text>
      <text class="starter-picked__copy">{{selectedLaunchReason}}</text>
    </view>

    <view class="topic-stack">
      <view
        wx:for="{{recommendedTopics}}"
        wx:key="id"
        class="starter-topic starter-topic--{{index}} {{selectedTopicId === item.id ? 'starter-topic--selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectTopic"
      >
        <view class="starter-topic__mist starter-topic__mist--a"></view>
        <view class="starter-topic__mist starter-topic__mist--b"></view>
        <view class="starter-topic__header">
          <view class="starter-topic__status">
            <view class="starter-topic__dot"></view>
            <text class="starter-topic__status-label">{{item.status}}</text>
          </view>
          <text class="starter-topic__seat">{{item.current}}/{{item.total}} 匹配度</text>
        </view>
        <view class="starter-topic__body">
          <text class="starter-topic__depth">{{item.depth}}</text>
          <text class="starter-topic__title">{{item.title}}</text>
          <view class="starter-topic__meta-row">
            <text class="starter-topic__initiator">{{item.initiator}}</text>
            <text class="starter-topic__meta"> · {{item.time}} · {{item.location}}</text>
          </view>
          <view class="starter-topic__tags">
            <text wx:for="{{item.tags}}" wx:key="index" class="starter-topic__pill">{{item}}</text>
          </view>
          <text class="starter-topic__reason">{{item.reason}}</text>
        </view>
        <view class="starter-topic__openers">
          <text wx:for="{{item.openers}}" wx:key="index" class="starter-topic__opener">{{item}}</text>
        </view>
        <view class="starter-topic__footer">
          <text class="starter-topic__rules">{{item.rules}}</text>
          <view class="starter-topic__select">{{selectedTopicId === item.id ? '当前已选' : '选这个发起'}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="starter-footer">
    <view class="starter-footer__secondary" bindtap="goBack">{{currentStep === 0 ? '返回上一页' : '上一步'}}</view>
    <view class="starter-footer__primary" bindtap="nextStep">{{currentStep === 2 ? '带着这张卡去发起' : '继续生成这张卡'}}</view>
  </view>
</view>
