.profile-page {
  position: relative;
}

.profile-banner {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.profile-banner__eyebrow {
  color: rgba(243, 241, 231, 0.34);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  line-height: 1;
}

.profile-banner__title {
  color: #f3f1e7;
  font-size: 80rpx;
  line-height: 0.92;
  letter-spacing: -3rpx;
  font-weight: 700;
}

.profile-hero {
  margin-top: 16rpx;
  margin-bottom: 28rpx;
  padding: 10rpx 4rpx 6rpx;
}

.profile-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #6f787f, #beb6b0 56%, #b98f69);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 22rpx;
}

.profile-avatar__initial {
  font-size: 58rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1;
}

.profile-name {
  display: block;
  font-size: 80rpx;
  font-weight: 700;
  line-height: 0.92;
  letter-spacing: -3rpx;
  color: #f3f1e7;
  margin-bottom: 18rpx;
}

.profile-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-edit {
  margin-top: 10rpx;
  min-width: 144rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(243, 241, 231, 0.78);
  font-size: 22rpx;
  box-sizing: border-box;
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, background 180ms ease, opacity 180ms ease;
}

.profile-edit--pressed {
  transform: translateY(4rpx) scale(0.98);
  background: rgba(255, 255, 255, 0.06);
  opacity: 0.92;
}

.profile-bio-lines {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.profile-bio-line {
  font-size: 26rpx;
  color: rgba(243, 241, 231, 0.78);
  line-height: 1.5;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-tags .pill {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: rgba(243, 241, 231, 0.88);
}

.profile-firelight {
  margin: 8rpx 0 26rpx;
}

.profile-firelight__summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-firelight__count {
  color: rgba(243, 241, 231, 0.72);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.profile-firelight__row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.profile-firelight__flame {
  position: relative;
  width: 34rpx;
  height: 34rpx;
}

.profile-firelight__image {
  display: block;
  width: 100%;
  height: 100%;
}

.profile-firelight__pixel {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  image-rendering: pixelated;
}

.profile-firelight__pixel--top {
  top: 0;
  width: 10rpx;
  height: 10rpx;
  background: #fff2be;
  box-shadow: 0 0 8rpx rgba(255, 224, 153, 0.18);
}

.profile-firelight__pixel--mid {
  top: 8rpx;
  width: 16rpx;
  height: 14rpx;
  background: #f3a24c;
  box-shadow:
    -8rpx 4rpx 0 0 #ffd56c,
    8rpx 4rpx 0 0 #d6782c,
    0 14rpx 0 0 #bf5c1f;
}

.profile-firelight__stick {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 6rpx;
  height: 16rpx;
  background: #6f4a2c;
  box-shadow: inset 0 0 0 1rpx rgba(36, 22, 14, 0.18);
}

.profile-firelight__stick--left {
  transform: translateX(-5rpx) rotate(24deg);
}

.profile-firelight__stick--right {
  transform: translateX(1rpx) rotate(-24deg);
}

.profile-firelight__hint {
  margin-top: 14rpx;
  max-width: 440rpx;
  color: rgba(243, 241, 231, 0.56);
  font-size: 23rpx;
  line-height: 1.6;
}

.profile-firelight__flame--script .profile-firelight__pixel--top {
  top: -1rpx;
  width: 12rpx;
  height: 16rpx;
  background: linear-gradient(180deg, #ffe59b 0%, #ffb255 58%, #f06e2f 100%);
  border-radius: 70% 70% 48% 48%;
  transform: translateX(-10%) rotate(28deg);
  box-shadow: 0 0 8rpx rgba(255, 176, 85, 0.18);
}

.profile-firelight__flame--script .profile-firelight__pixel--mid {
  top: 12rpx;
  width: 14rpx;
  height: 16rpx;
  background: linear-gradient(180deg, #ffcf73 0%, #ff9a45 52%, #df5628 100%);
  border-radius: 48% 48% 42% 42%;
  box-shadow:
    -11rpx 8rpx 0 0 #ff9141,
    11rpx 8rpx 0 0 #ff9141,
    0 16rpx 0 0 #ff7d36;
}

.profile-firelight__flame--script .profile-firelight__stick {
  width: 7rpx;
  height: 20rpx;
  background: linear-gradient(180deg, #ff8d3d 0%, #da5829 100%);
  box-shadow: none;
}

.profile-firelight__flame--script .profile-firelight__stick--left {
  transform: translateX(-7rpx) rotate(28deg);
}

.profile-firelight__flame--script .profile-firelight__stick--right {
  transform: translateX(1rpx) rotate(-28deg);
}

.profile-firelight__flame--ember .profile-firelight__pixel--top {
  top: -2rpx;
  width: 10rpx;
  height: 13rpx;
  background: linear-gradient(180deg, #fff0b8 0%, #ffc96a 100%);
  border-radius: 72% 72% 46% 46%;
  transform: translateX(-50%) rotate(12deg);
}

.profile-firelight__flame--ember .profile-firelight__pixel--mid {
  top: 9rpx;
  width: 18rpx;
  height: 18rpx;
  background: linear-gradient(180deg, #ffd36f 0%, #ff9b47 56%, #eb682f 100%);
  border-radius: 58% 58% 46% 46%;
  box-shadow:
    -6rpx 8rpx 0 -1rpx #ffb252,
    6rpx 8rpx 0 -1rpx #ffb252,
    0 18rpx 0 -1rpx #de5d2a;
}

.profile-firelight__flame--ember .profile-firelight__stick--left,
.profile-firelight__flame--ember .profile-firelight__stick--right {
  display: none;
}

.profile-firelight__flame--spark .profile-firelight__pixel--top {
  top: 0;
  width: 9rpx;
  height: 14rpx;
  background: linear-gradient(180deg, #fff0b8 0%, #ffca67 100%);
  border-radius: 3rpx 10rpx 3rpx 8rpx;
  transform: translateX(-20%) rotate(30deg);
}

.profile-firelight__flame--spark .profile-firelight__pixel--mid {
  top: 11rpx;
  width: 15rpx;
  height: 15rpx;
  background: linear-gradient(180deg, #ffc861 0%, #ff943f 50%, #db5329 100%);
  border-radius: 4rpx;
  box-shadow:
    -10rpx 7rpx 0 -2rpx #ff9d44,
    10rpx 7rpx 0 -2rpx #ff9d44,
    0 17rpx 0 -2rpx #de5b2a;
}

.profile-firelight__flame--spark .profile-firelight__stick {
  width: 6rpx;
  height: 18rpx;
  background: linear-gradient(180deg, #ff8b3a 0%, #d85228 100%);
  box-shadow: none;
}

.profile-firelight__flame--spark .profile-firelight__stick--left {
  transform: translateX(-7rpx) rotate(36deg);
}

.profile-firelight__flame--spark .profile-firelight__stick--right {
  transform: translateX(1rpx) rotate(-18deg);
}

.event-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 18rpx;
}

.event-head__eyebrow {
  display: block;
  margin-bottom: 10rpx;
  font-size: 18rpx;
  color: rgba(243, 241, 231, 0.34);
  letter-spacing: 5rpx;
}

.event-head__title {
  display: block;
  font-size: 54rpx;
  color: rgba(243, 241, 231, 0.94);
  font-weight: 700;
  line-height: 1.04;
}

.event-head__copy {
  display: block;
  margin-top: 14rpx;
  max-width: 500rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(243, 241, 231, 0.52);
}

.event-head__count {
  padding-top: 46rpx;
  color: rgba(243, 241, 231, 0.42);
  font-size: 26rpx;
  white-space: nowrap;
}

.profile-thought-list {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
}

.profile-thought-card {
  padding: 24rpx 24rpx 22rpx;
  border-radius: 28rpx;
  box-shadow:
    0 16rpx 36rpx rgba(0, 0, 0, 0.16),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.14);
}

.profile-thought-card--0 {
  background:
    radial-gradient(circle at 82% 16%, rgba(245, 233, 183, 0.24), transparent 24%),
    linear-gradient(145deg, rgba(146, 166, 178, 0.94), rgba(186, 168, 159, 0.92) 42%, rgba(216, 190, 151, 0.94) 100%);
}

.profile-thought-card--1 {
  background:
    radial-gradient(circle at 82% 18%, rgba(244, 221, 197, 0.22), transparent 24%),
    linear-gradient(145deg, rgba(217, 198, 182, 0.94), rgba(198, 208, 188, 0.92) 58%, rgba(228, 206, 186, 0.92));
}

.profile-thought-card--2 {
  background:
    radial-gradient(circle at 80% 16%, rgba(196, 218, 255, 0.22), transparent 24%),
    linear-gradient(145deg, rgba(165, 182, 198, 0.94), rgba(197, 205, 218, 0.92) 52%, rgba(213, 191, 176, 0.92));
}

.profile-thought-card--3 {
  background:
    radial-gradient(circle at 18% 84%, rgba(245, 195, 208, 0.2), transparent 24%),
    linear-gradient(145deg, rgba(214, 194, 202, 0.94), rgba(190, 177, 193, 0.92) 54%, rgba(222, 194, 182, 0.92));
}

.profile-thought-card--4 {
  background:
    radial-gradient(circle at 82% 18%, rgba(250, 238, 210, 0.24), transparent 24%),
    linear-gradient(145deg, rgba(210, 206, 194, 0.94), rgba(181, 188, 198, 0.92) 56%, rgba(214, 198, 176, 0.92));
}

.profile-thought-card__title {
  display: block;
  color: #111111;
  font-size: 34rpx;
  line-height: 1.22;
  font-weight: 700;
}

.profile-thought-card__copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(17, 17, 17, 0.68);
  font-size: 22rpx;
  line-height: 1.6;
}

.profile-thought-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  color: rgba(17, 17, 17, 0.5);
  font-size: 18rpx;
}

.profile-thought-expand {
  margin-top: 18rpx;
  min-height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  color: rgba(243, 241, 231, 0.78);
  font-size: 24rpx;
  font-weight: 600;
}

.idea-plus {
  width: 72rpx;
  height: 72rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #f3f1e7;
  font-size: 44rpx;
  line-height: 1;
  box-sizing: border-box;
  transition: transform 160ms ease, opacity 160ms ease, background 180ms ease;
}

.idea-plus--pressed {
  transform: translateY(4rpx) scale(0.97);
  opacity: 0.92;
}

.event-swiper {
  height: 760rpx;
}

.event-slide {
  height: 100%;
  padding: 0 10rpx;
}

.event-card {
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  height: 736rpx;
  padding: 34rpx 34rpx 40rpx;
  box-shadow:
    0 24rpx 60rpx rgba(0, 0, 0, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transform: translateY(0) scale(1);
  transition: transform 180ms ease, box-shadow 220ms ease, filter 220ms ease;
  z-index: 2;
}

.idea-card {
  padding: 0;
  background: #0a0b0b;
  display: flex;
  flex-direction: column;
}

.event-card--pressed {
  transform: translateY(8rpx) scale(0.986);
  box-shadow:
    0 12rpx 30rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  filter: saturate(1.04);
}

.event-card--0 {
  background:
    radial-gradient(circle at 84% 18%, rgba(245, 233, 183, 0.34), transparent 28%),
    linear-gradient(145deg, #92a6b2 0%, #baa89f 42%, #d8be97 100%);
}

.event-card--1 {
  background:
    radial-gradient(circle at 80% 16%, rgba(255, 248, 208, 0.28), transparent 26%),
    linear-gradient(145deg, #b7b7cd 0%, #cdbdad 48%, #bcc8a2 100%);
}

.event-card--2 {
  background:
    radial-gradient(circle at 82% 16%, rgba(247, 234, 173, 0.26), transparent 24%),
    linear-gradient(145deg, #547468 0%, #7f8f7e 48%, #d1c39f 100%);
}

.event-card--3 {
  background:
    radial-gradient(circle at 80% 18%, rgba(245, 232, 185, 0.24), transparent 26%),
    linear-gradient(145deg, #e4ddd2 0%, #c7bdaf 54%, #ede2d2 100%);
}

.event-card--4 {
  background:
    radial-gradient(circle at 80% 16%, rgba(248, 226, 171, 0.28), transparent 24%),
    linear-gradient(145deg, #9aa0b2 0%, #938475 52%, #cbb393 100%);
}

.idea-card__hero {
  min-height: 390rpx;
  padding: 30rpx 30rpx 34rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.idea-card__hero--0 {
  background:
    radial-gradient(circle at 78% 16%, rgba(245, 233, 183, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(146, 166, 178, 0.98), rgba(186, 168, 159, 0.95) 52%, rgba(216, 190, 151, 0.98) 100%);
}

.idea-card__hero--1 {
  background:
    radial-gradient(circle at 82% 18%, rgba(244, 221, 197, 0.26), transparent 26%),
    linear-gradient(180deg, rgba(217, 198, 182, 0.98), rgba(198, 208, 188, 0.96) 58%, rgba(228, 206, 186, 0.96));
}

.idea-card__hero--2 {
  background:
    radial-gradient(circle at 78% 16%, rgba(196, 218, 255, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(165, 182, 198, 0.98), rgba(197, 205, 218, 0.96) 52%, rgba(213, 191, 176, 0.96));
}

.idea-card__hero--3 {
  background:
    radial-gradient(circle at 18% 84%, rgba(245, 195, 208, 0.26), transparent 26%),
    linear-gradient(180deg, rgba(214, 194, 202, 0.98), rgba(190, 177, 193, 0.96) 54%, rgba(222, 194, 182, 0.96));
}

.idea-card__hero--4 {
  background:
    radial-gradient(circle at 82% 18%, rgba(250, 238, 210, 0.28), transparent 26%),
    linear-gradient(180deg, rgba(210, 206, 194, 0.98), rgba(181, 188, 198, 0.96) 56%, rgba(214, 198, 176, 0.96));
}

.idea-card__topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.idea-card__body {
  flex: 1;
  min-height: 0;
  padding: 30rpx 30rpx 34rpx;
  box-sizing: border-box;
  background: #0a0b0b;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.event-card__mist {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 240rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
  filter: blur(28rpx);
  transition: transform 220ms ease, opacity 220ms ease;
}

.event-card__body {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: transform 220ms ease;
}

.event-card--pressed .event-card__mist {
  transform: translate3d(-12rpx, 10rpx, 0) scale(0.96);
  opacity: 0.78;
}

.event-card--pressed .event-card__body {
  transform: translateY(6rpx);
}

.event-card__topline,
.event-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.event-card__tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(68, 74, 75, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.92);
}

.event-card__date,
.event-card__foot,
.event-card__index {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.78);
}

.event-card__title {
  display: block;
  max-width: 520rpx;
  font-size: 48rpx;
  line-height: 1.18;
  color: #ffffff;
  font-weight: 700;
}

.idea-card__quote {
  display: block;
  max-width: 500rpx;
  color: rgba(243, 241, 231, 0.84);
  font-size: 26rpx;
  line-height: 1.68;
  max-height: 176rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.event-card__footer {
  margin-top: 20rpx;
}

.event-card__footer-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.event-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 14rpx;
  margin-bottom: 18rpx;
}

.event-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.event-dot--active {
  width: 42rpx;
  border-radius: 999rpx;
  background: #b8ae76;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 6rpx;
}

.entry-card {
  min-height: 248rpx;
  border-radius: 34rpx;
  padding: 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 14rpx 34rpx rgba(0, 0, 0, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  transform: translateY(0) scale(1);
  transition: transform 180ms ease, box-shadow 220ms ease, filter 220ms ease;
  position: relative;
  z-index: 2;
}

.entry-card--pressed {
  transform: translateY(6rpx) scale(0.986);
  box-shadow:
    0 10rpx 24rpx rgba(0, 0, 0, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  filter: saturate(1.03);
}

.entry-card--unlock {
  background:
    radial-gradient(circle at 84% 16%, rgba(243, 228, 173, 0.24), transparent 34%),
    linear-gradient(145deg, rgba(150, 174, 193, 0.95), rgba(205, 193, 184, 0.82) 56%, rgba(220, 194, 152, 0.86));
}

.entry-card--cobuild {
  background:
    radial-gradient(circle at 84% 18%, rgba(244, 221, 197, 0.28), transparent 32%),
    linear-gradient(145deg, rgba(217, 198, 182, 0.96), rgba(198, 208, 188, 0.84) 58%, rgba(228, 206, 186, 0.86));
}

.entry-card__content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: transform 220ms ease;
}

.entry-card--pressed .entry-card__content {
  transform: translateY(4rpx);
}

.entry-card__eyebrow {
  display: block;
  color: rgba(17, 17, 17, 0.46);
  font-size: 17rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.entry-card__title {
  display: block;
  color: #111111;
  font-size: 30rpx;
  line-height: 1.28;
  font-weight: 700;
}

.entry-card__copy {
  display: block;
  color: rgba(17, 17, 17, 0.62);
  font-size: 22rpx;
  line-height: 1.52;
}

.entry-card__button {
  margin-top: 8rpx;
  align-self: flex-start;
  min-width: 132rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #111111;
  font-size: 22rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 10rpx 18rpx rgba(0, 0, 0, 0.08),
    0 0 20rpx rgba(255, 255, 255, 0.16);
  transition: transform 180ms ease, box-shadow 220ms ease, filter 220ms ease;
}

.entry-card--pressed .entry-card__button {
  transform: translateY(3rpx) scale(0.97);
  box-shadow:
    0 6rpx 12rpx rgba(0, 0, 0, 0.08),
    0 0 12rpx rgba(255, 255, 255, 0.1);
  filter: brightness(0.98);
}

.event-modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 320;
  background:
    radial-gradient(circle at 74% 10%, rgba(245, 231, 141, 0.1), transparent 26%),
    radial-gradient(circle at 22% 76%, rgba(166, 199, 228, 0.08), transparent 28%),
    #050505;
  display: flex;
  align-items: stretch;
  justify-content: center;
  animation: eventModalFadeIn 220ms ease;
}

.event-modal-sheet {
  width: 100%;
  min-height: 100vh;
  padding: calc(64rpx + env(safe-area-inset-top)) 40rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: eventModalFadeIn 220ms ease;
}

.event-modal-sheet__handle {
  width: 80rpx;
  height: 8rpx;
  margin: 0 auto 26rpx;
  border-radius: 999rpx;
  background: rgba(243, 241, 231, 0.18);
}

.idea-composer {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: calc(100vh - 128rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.idea-composer__eyebrow {
  color: rgba(243, 241, 231, 0.34);
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.idea-composer__title {
  display: block;
  margin-top: 14rpx;
  color: #f3f1e7;
  font-size: 48rpx;
  line-height: 1.08;
  font-weight: 700;
}

.idea-composer__copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.56);
  font-size: 24rpx;
  line-height: 1.6;
}

.thought-composer-grid {
  width: 100%;
  height: min(1180rpx, calc(100vh - 220rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom)));
  min-height: 920rpx;
  margin-top: 0;
  display: grid;
  grid-template-rows: 3fr 7fr;
  overflow: hidden;
  border-radius: 22rpx;
  border: 18rpx solid #050505;
  background: #050505;
  box-shadow:
    0 28rpx 90rpx rgba(0, 0, 0, 0.42),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.thought-composer-grid__panel {
  position: relative;
  padding: 28rpx 28rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.thought-composer-grid--halves .thought-composer-grid__panel {
  min-height: 0;
}

.thought-composer-grid__panel--merged-top {
  background:
    radial-gradient(circle at 34% 24%, rgba(248, 227, 151, 0.18), transparent 18%),
    radial-gradient(circle at 76% 30%, rgba(206, 217, 148, 0.18), transparent 24%),
    linear-gradient(90deg, rgba(185, 150, 136, 0.96) 0%, rgba(187, 176, 139, 0.94) 100%);
}

.thought-composer-grid__panel--merged-bottom {
  background:
    radial-gradient(circle at 24% 28%, rgba(235, 235, 241, 0.18), transparent 22%),
    radial-gradient(circle at 80% 22%, rgba(239, 211, 153, 0.16), transparent 22%),
    linear-gradient(90deg, rgba(206, 203, 207, 0.96) 0%, rgba(209, 198, 184, 0.94) 100%);
  border-top: 10rpx solid #050505;
}

.thought-composer-grid__eyebrows {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.thought-composer-grid__eyebrow {
  color: rgba(243, 241, 231, 0.58);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
  font-weight: 700;
}

.thought-composer-grid__topic,
.thought-composer-grid__body {
  width: 100%;
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
  padding: 0;
  box-sizing: border-box;
  background: transparent;
}

.thought-composer-grid__topic {
  height: 100%;
  color: #f7f3e8;
  font-size: 66rpx;
  line-height: 1.12;
  font-weight: 700;
}

.thought-composer-grid__body {
  color: rgba(20, 20, 20, 0.84);
  font-size: 28rpx;
  line-height: 1.62;
  font-weight: 600;
  padding-bottom: 24rpx;
}

.idea-composer__placeholder {
  color: rgba(247, 243, 232, 0.38);
}

.thought-composer-grid__panel--merged-bottom .idea-composer__placeholder {
  color: rgba(20, 20, 20, 0.32);
}

.idea-composer__actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.idea-composer__ghost,
.idea-composer__primary {
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.idea-composer__ghost {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.idea-composer__primary {
  flex: 1.2;
  background: linear-gradient(135deg, #f3e2b6, #e8c06d);
  color: #17130f;
}

.idea-composer__ghost--pressed,
.idea-composer__primary--pressed {
  transform: translateY(4rpx) scale(0.98);
}

.event-modal-card__center {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.event-modal-card__title {
  display: block;
  max-width: 520rpx;
  font-size: 56rpx;
  line-height: 1.1;
  letter-spacing: -1.2rpx;
  color: #ffffff;
  font-weight: 700;
  text-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.12);
}

.event-modal-card__text {
  display: block;
  max-width: 540rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.84);
  font-weight: 500;
}

.event-modal-card__anchor {
  display: block;
  max-width: 520rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.62);
}

.event-modal-panels {
  display: block;
  margin-top: 18rpx;
}

.event-modal-panel {
  min-height: 220rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.event-modal-panel__eyebrow {
  display: block;
  margin-bottom: 12rpx;
  font-size: 20rpx;
  letter-spacing: 1.2rpx;
  color: rgba(243, 241, 231, 0.42);
}

.event-modal-panel__text {
  display: block;
  font-size: 28rpx;
  line-height: 1.48;
  color: rgba(243, 241, 231, 0.92);
  font-weight: 600;
}

.event-modal-panel__sub {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.58;
  color: rgba(243, 241, 231, 0.52);
}

.event-modal-actions {
  margin-top: 24rpx;
}

.event-modal-actions__row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.event-modal-btn {
  height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, box-shadow 180ms ease, opacity 180ms ease, filter 180ms ease;
}

.event-modal-btn--primary {
  background: linear-gradient(135deg, #f1eddd, #d8cfb5);
  color: #111111;
  box-shadow:
    0 10rpx 18rpx rgba(0, 0, 0, 0.12),
    0 0 24rpx rgba(255, 245, 216, 0.12);
}

.event-modal-btn--ghost {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(243, 241, 231, 0.84);
}

.event-modal-btn--text {
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.58);
}

.event-modal-btn--pressed {
  transform: translateY(4rpx) scale(0.98);
  opacity: 0.86;
  filter: brightness(0.98);
}

@keyframes eventModalFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes eventModalSlideUp {
  from {
    opacity: 0;
    transform: translateY(100%);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
