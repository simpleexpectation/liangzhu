<view class="page-shell profile-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <nav-shell compact>
    <view class="profile-banner">
      <text class="profile-banner__eyebrow">计划良渚</text>
      <text class="profile-banner__title">我的</text>
    </view>
  </nav-shell>

  <view class="profile-hero">
    <view class="profile-avatar">
      <text class="profile-avatar__initial">{{user.initial}}</text>
    </view>
    <view class="profile-heading">
      <text class="profile-name">{{user.name}}</text>
      <view class="profile-edit {{pressedProfileAction === 'edit' ? 'profile-edit--pressed' : ''}}" data-action="edit" bindtouchstart="pressProfileAction" bindtouchend="releaseProfileAction" bindtouchcancel="releaseProfileAction" bindtap="editProfile">
        编辑资料
      </view>
    </view>
    <view class="profile-bio-lines">
      <text class="profile-bio-line">◈  {{user.bio}}</text>
      <text class="profile-bio-line">⌖  {{user.location}}</text>
    </view>
    <view class="profile-tags">
      <view wx:for="{{user.tags}}" wx:key="index" class="pill">{{item}}</view>
    </view>
  </view>

  <view class="profile-firelight">
    <view class="profile-firelight__summary" bindtap="toggleFirelightHint">
      <view class="profile-firelight__row">
        <view wx:for="{{firelights}}" wx:key="id" class="profile-firelight__flame">
          <image class="profile-firelight__image" mode="aspectFit" src="{{firelightIconSrc}}" />
        </view>
      </view>
      <text class="profile-firelight__count">{{firelightCount}}</text>
    </view>
    <view wx:if="{{showFirelightHint}}" class="profile-firelight__hint">
      每参加过一次见面，就在这里留下一点火光。
    </view>
  </view>

  <view class="event-head">
    <view>
      <text class="event-head__eyebrow">MY THOUGHTS</text>
      <text class="event-head__title">我的思考</text>
      <text class="event-head__copy">把最近最想说的一句话留在这里，它会慢慢长成你的思考卡。</text>
    </view>
    <view class="idea-plus {{pressedIdeaAction === 'plus' ? 'idea-plus--pressed' : ''}}" data-action="plus" bindtouchstart="pressIdeaAction" bindtouchend="releaseIdeaAction" bindtouchcancel="releaseIdeaAction" bindtap="openIdeaComposer">+</view>
  </view>

  <view class="profile-thought-list">
    <view
      wx:for="{{visibleIdeaCards}}"
      wx:key="id"
      class="profile-thought-card profile-thought-card--{{item.tone}}"
      data-thought-id="{{item.id}}"
      bindtap="openIdeaDetail"
    >
      <text class="profile-thought-card__title">{{item.title}}</text>
      <text class="profile-thought-card__copy">{{item.quote}}</text>
      <view class="profile-thought-card__footer">
        <text>{{item.createdAt}}</text>
        <text>思考详情</text>
      </view>
    </view>
  </view>

  <view wx:if="{{ideaCards.length > 3}}" class="profile-thought-expand" bindtap="toggleThoughtsExpanded">
    {{thoughtsExpanded ? '收起' : '展开全部'}}
  </view>

  <view class="entry-grid">
    <view class="entry-card entry-card--unlock {{pressedEntry === 'unlock' ? 'entry-card--pressed' : ''}}" data-entry="unlock" bindtouchstart="pressEntryCard" bindtouchend="releaseEntryCard" bindtouchcancel="releaseEntryCard" bindtap="openInviteUnlock">
      <view class="entry-card__content">
        <text class="entry-card__eyebrow">{{unlockEntry.badge}}</text>
        <text class="entry-card__title">{{unlockEntry.title}}</text>
        <text class="entry-card__copy">{{unlockEntry.detail}}</text>
        <view class="entry-card__button">{{unlockEntry.cta}}</view>
      </view>
    </view>

    <view class="entry-card entry-card--cobuild {{pressedEntry === 'cobuild' ? 'entry-card--pressed' : ''}}" data-entry="cobuild" bindtouchstart="pressEntryCard" bindtouchend="releaseEntryCard" bindtouchcancel="releaseEntryCard" bindtap="openCoBuildPlan">
      <view class="entry-card__content">
        <text class="entry-card__eyebrow">{{coBuildEntry.badge}}</text>
        <text class="entry-card__title">{{coBuildEntry.title}}</text>
        <text class="entry-card__copy">{{coBuildEntry.detail}}</text>
        <view class="entry-card__button">{{coBuildEntry.cta}}</view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showIdeaComposer}}" class="event-modal-mask" bindtap="closeIdeaComposer">
  <view class="event-modal-sheet" catchtap="">
    <view class="idea-composer">
      <view class="thought-composer-grid thought-composer-grid--halves">
        <view class="thought-composer-grid__panel thought-composer-grid__panel--merged-top" bindtap="focusIdeaTopic">
          <view class="thought-composer-grid__eyebrows">
            <text class="thought-composer-grid__eyebrow">Tonight</text>
            <text class="thought-composer-grid__eyebrow">Liangzhu</text>
          </view>
          <input
            class="thought-composer-grid__topic"
            value="{{ideaDraft}}"
            bindinput="updateIdeaDraft"
            maxlength="40"
            hold-keyboard="{{true}}"
            focus="{{composerFocus === 'topic'}}"
            placeholder="写一句主题"
            placeholder-class="idea-composer__placeholder"
          />
        </view>
        <view class="thought-composer-grid__panel thought-composer-grid__panel--merged-bottom" bindtap="focusIdeaBody">
          <view class="thought-composer-grid__eyebrows">
            <text class="thought-composer-grid__eyebrow">Meet</text>
            <text class="thought-composer-grid__eyebrow">Topic</text>
          </view>
          <textarea
            class="thought-composer-grid__body"
            value="{{ideaBodyDraft}}"
            bindinput="updateIdeaBodyDraft"
            maxlength="1200"
            auto-height="{{false}}"
            show-confirm-bar="{{false}}"
            hold-keyboard="{{true}}"
            focus="{{composerFocus === 'body'}}"
            disable-default-padding="{{true}}"
            placeholder="把详细的思考写在这里。"
            placeholder-class="idea-composer__placeholder"
          />
        </view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showThoughtDetail}}" class="thought-modal" bindtap="closeThoughtDetail">
  <view class="thought-modal__window {{thoughtDetailExpanded ? 'thought-modal__window--expanded' : ''}}" catchtap="">
    <scroll-view scroll-y="{{thoughtDetailExpanded}}" class="thought-modal__scroll {{thoughtDetailExpanded ? 'thought-modal__scroll--expanded' : ''}}">
      <view class="thought-modal__hero thought-modal__hero--{{selectedThought.tone}}">
        <text class="thought-modal__label">THOUGHT</text>
        <text class="thought-modal__title">{{selectedThought.title}}</text>
      </view>
      <view class="thought-modal__body">
        <text class="thought-modal__text {{thoughtDetailExpanded ? 'thought-modal__text--expanded' : ''}}">{{selectedThought.detailText}}</text>
        <view wx:if="{{selectedThought.canExpand && !thoughtDetailExpanded}}" class="thought-modal__expand" catchtap="expandThoughtDetail"></view>
      </view>
    </scroll-view>
  </view>
</view>
