.membership-topbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.membership-topbar__back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  color: #f3f1e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
}

.membership-topbar__title {
  color: #f3f1e7;
  font-size: 40rpx;
  font-weight: 600;
}

.membership-hero {
  margin-top: 24rpx;
  border-radius: 36rpx;
  padding: 32rpx 30rpx;
  background:
    radial-gradient(circle at 82% 14%, rgba(255,245,180,0.55), transparent 30%),
    radial-gradient(circle at 18% 80%, rgba(241,153,110,0.22), transparent 32%),
    linear-gradient(160deg, #8aaabf 0%, #b89d8a 48%, #e8c47a 100%);
  color: #17120f;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.5), inset 0 1rpx 0 rgba(255,255,255,0.2);
}

.membership-hero__intro {
  display: block;
  margin-top: 18rpx;
  max-width: 580rpx;
  color: rgba(23,19,18,0.58);
  font-size: 24rpx;
  line-height: 1.7;
}

.membership-hero__eyebrow {
  display: block;
  color: rgba(23,19,18,0.48);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.membership-hero__plan {
  display: block;
  margin-top: 14rpx;
  font-size: 48rpx;
  font-weight: 600;
  color: #17120f;
}

.membership-hero__price-row {
  display: flex;
  align-items: flex-end;
  margin-top: 22rpx;
  color: #17120f;
}

.membership-hero__currency {
  padding-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(23,19,18,0.55);
}

.membership-hero__price {
  font-size: 96rpx;
  line-height: 0.92;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.membership-hero__billing {
  padding: 0 0 12rpx 10rpx;
  font-size: 28rpx;
  color: rgba(23,19,18,0.5);
}

.membership-hero__renewal {
  display: block;
  margin-top: 12rpx;
  color: rgba(23,19,18,0.5);
  font-size: 22rpx;
}

.membership-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.membership-plan-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.membership-plan-card {
  border-radius: 32rpx;
  padding: 26rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.membership-plan-card--active {
  border-color: rgba(239, 225, 187, 0.48);
  box-shadow: 0 0 0 2rpx rgba(239, 225, 187, 0.06);
}

.membership-plan-card__badge {
  display: inline-flex;
  min-height: 40rpx;
  padding: 0 16rpx;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243,241,231,0.7);
  font-size: 18rpx;
}

.membership-plan-card__title {
  display: block;
  margin-top: 12rpx;
  color: rgba(243,241,231,0.94);
  font-size: 34rpx;
  font-weight: 700;
}

.membership-plan-card__price-row {
  display: flex;
  align-items: flex-end;
  margin-top: 10rpx;
}

.membership-plan-card__currency,
.membership-plan-card__billing {
  color: rgba(243,241,231,0.54);
  font-size: 24rpx;
  padding-bottom: 8rpx;
}

.membership-plan-card__price {
  color: rgba(243,241,231,0.94);
  font-size: 68rpx;
  line-height: 0.9;
  font-weight: 700;
}

.membership-plan-card__renewal {
  display: block;
  margin-top: 10rpx;
  color: rgba(243,241,231,0.48);
  font-size: 22rpx;
  line-height: 1.6;
}

.purchase-button,
.invite-entry-button {
  width: 100%;
  min-height: 96rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
}

.purchase-button {
  background: #f0efe3;
  color: #171412;
}

.purchase-button__price {
  font-size: 28rpx;
  font-weight: 600;
}

.invite-entry-button {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.invite-entry-button__text {
  color: rgba(243, 241, 231, 0.84);
  font-size: 25rpx;
}

.invite-panel {
  position: relative;
  margin-top: 22rpx;
  border-radius: 34rpx;
  padding: 30rpx 28rpx;
  background:
    radial-gradient(circle at 88% 14%, rgba(156,186,212,0.12), transparent 38%),
    linear-gradient(160deg, rgba(255,255,255,0.09), rgba(255,255,255,0.03));
  border: 1rpx solid rgba(156,186,212,0.12);
}

.invite-panel__quota-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(243, 241, 231, 0.14);
  color: rgba(243, 241, 231, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.invite-panel__eyebrow {
  display: block;
  color: rgba(239,225,187,0.55);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.invite-panel__title {
  display: block;
  margin-top: 12rpx;
  max-width: 470rpx;
  color: rgba(243,241,231,0.92);
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.invite-panel__description {
  display: block;
  margin-top: 18rpx;
  max-width: 540rpx;
  color: rgba(243,241,231,0.5);
  font-size: 22rpx;
  line-height: 1.7;
}

.membership-perks-head {
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: rgba(243,241,231,0.4);
}

.membership-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 6rpx;
}

.membership-item {
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  background:
    radial-gradient(circle at 88% 14%, rgba(239,225,187,0.1), transparent 38%),
    rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.07);
  color: rgba(243,241,231,0.72);
  font-size: 24rpx;
  line-height: 1.6;
}

.membership-footer {
  position: sticky;
  bottom: 0;
  padding: 16rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(5,5,5,0.98) 60%, transparent);
  margin-top: 10rpx;
}
