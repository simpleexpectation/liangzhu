.ai-entry-page {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 82% 10%, rgba(245, 231, 141, 0.12), transparent 24%),
    radial-gradient(circle at 18% 18%, rgba(174, 202, 229, 0.1), transparent 24%),
    radial-gradient(circle at 20% 72%, rgba(236, 181, 136, 0.1), transparent 24%),
    linear-gradient(180deg, #151210 0%, #120f12 42%, #110f14 100%);
}

.ai-entry-page__glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(96rpx);
  pointer-events: none;
  opacity: 0.7;
}

.ai-entry-page__glow--a {
  width: 420rpx;
  height: 340rpx;
  top: 100rpx;
  right: -40rpx;
  background: rgba(243, 224, 144, 0.14);
}

.ai-entry-page__glow--b {
  width: 340rpx;
  height: 300rpx;
  left: -20rpx;
  top: 660rpx;
  background: rgba(166, 199, 228, 0.12);
}

.ai-entry-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ai-entry-nav__back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 250, 242, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  color: #f3f1e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
}

.ai-entry-nav__copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ai-entry-nav__title {
  color: #f3f1e7;
  font-size: 42rpx;
  font-weight: 600;
}

.ai-entry-nav__sub {
  color: rgba(243, 241, 231, 0.46);
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-entry-composer {
  position: relative;
  overflow: hidden;
  margin-top: 36rpx;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 42rpx;
  background:
    radial-gradient(circle at 84% 14%, rgba(247, 225, 170, 0.16), transparent 22%),
    radial-gradient(circle at 18% 84%, rgba(215, 178, 144, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(250, 246, 239, 0.16), rgba(255, 255, 255, 0.07));
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 30rpx 84rpx rgba(0, 0, 0, 0.22);
}

.ai-entry-composer__mist {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(18rpx);
}

.ai-entry-composer__mist--a {
  right: 18rpx;
  top: -20rpx;
  width: 220rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(246, 235, 184, 0.16), rgba(246, 235, 184, 0));
}

.ai-entry-composer__mist--b {
  left: -24rpx;
  bottom: -20rpx;
  width: 220rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(231, 170, 132, 0.12), rgba(231, 170, 132, 0));
}

.ai-entry-composer__head,
.ai-entry-composer__textarea,
.ai-entry-composer__chips {
  position: relative;
  z-index: 1;
}

.ai-entry-composer__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.ai-entry-composer__copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ai-entry-composer__title {
  color: #f3f1e7;
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: -0.8rpx;
}

.ai-entry-composer__sub {
  color: rgba(243, 241, 231, 0.54);
  font-size: 22rpx;
  line-height: 1.6;
}

.ai-entry-composer__record {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(241, 225, 184, 0.18), rgba(235, 195, 128, 0.08));
  color: #f3f1e7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.ai-entry-composer__textarea {
  width: 100%;
  margin-top: 24rpx;
  min-height: 228rpx;
  padding: 28rpx 28rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 84% 16%, rgba(243, 229, 146, 0.06), transparent 18%),
    rgba(255, 248, 239, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  color: #f3f1e7;
  font-size: 30rpx;
  line-height: 1.8;
}

.ai-entry-composer__placeholder {
  color: rgba(243, 241, 231, 0.24);
}

.ai-entry-composer__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.ai-entry-composer__chip {
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(243, 241, 231, 0.74);
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.ai-entry-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.ai-entry-actions__secondary,
.ai-entry-actions__primary {
  min-height: 94rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.ai-entry-actions__secondary {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  color: rgba(243, 241, 231, 0.82);
}

.ai-entry-actions__primary {
  flex: 1.15;
  background: linear-gradient(135deg, #f0dfb3, #e9c271);
  color: #17130f;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.14);
}

.ai-entry-processing {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(15, 12, 11, 0.46);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  backdrop-filter: blur(8rpx);
}

.ai-entry-processing__panel {
  position: relative;
  overflow: hidden;
  width: 100%;
  padding: 34rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 82% 14%, rgba(245, 229, 143, 0.3), transparent 22%),
    radial-gradient(circle at 18% 84%, rgba(167, 198, 224, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.28);
}

.ai-entry-processing__glow {
  position: absolute;
  right: 24rpx;
  top: -16rpx;
  width: 220rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(247, 235, 171, 0.24), rgba(247, 235, 171, 0));
  filter: blur(16rpx);
}

.ai-entry-processing__eyebrow,
.ai-entry-processing__title,
.ai-entry-processing__copy,
.ai-entry-processing__steps {
  position: relative;
  z-index: 1;
}

.ai-entry-processing__eyebrow {
  color: rgba(243, 241, 231, 0.46);
  font-size: 18rpx;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.ai-entry-processing__title {
  display: block;
  margin-top: 14rpx;
  color: #f3f1e7;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 600;
}

.ai-entry-processing__copy {
  display: block;
  margin-top: 14rpx;
  color: rgba(243, 241, 231, 0.7);
  font-size: 22rpx;
  line-height: 1.65;
}

.ai-entry-processing__steps {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.ai-entry-processing__step {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ai-entry-processing__step-label {
  width: 120rpx;
  color: rgba(243, 241, 231, 0.74);
  font-size: 20rpx;
}

.ai-entry-processing__step-bar {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(241, 225, 184, 0.96), rgba(237, 198, 128, 0.92));
  box-shadow: 0 0 14rpx rgba(241, 225, 184, 0.22);
}
