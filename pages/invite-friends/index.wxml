<view class="page-shell invite-friends-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <view class="invite-page__glow invite-page__glow--a"></view>
  <view class="invite-page__glow invite-page__glow--b"></view>

  <view class="detail-topbar" style="padding-top: {{statusBarHeight + 14}}px;">
    <view class="detail-topbar__back" bindtap="goBack">← 返回</view>
  </view>

  <view class="detail-section">
    <text class="detail-page__title">邀请好友，0 元开启</text>
    <text class="detail-page__desc">邀请 2 位好友后，直接跳过这次 99 元付费。好友完成注册并参与第一次对话后，你的月卡自动生效。</text>

    <view class="code-card">
      <view>
        <text class="code-card__label">你的邀请码</text>
        <text class="code-card__value">{{inviteCode}}</text>
      </view>
      <view class="code-card__button" bindtap="copyInviteCode">复制</view>
    </view>

    <view class="board-card">
      <text class="board-card__eyebrow">Energy board · 你已经点亮第一格，再邀请 2 位同频好友就够了</text>
      <view class="board-grid">
        <view wx:for="{{unlockSlots}}" wx:key="key" class="board-node">
          <view class="board-node__orb {{item.active ? 'board-node__orb--active' : ''}}"></view>
          <text class="board-node__status">{{item.status}}</text>
          <text class="board-node__label">{{item.label}}</text>
        </view>
      </view>
      <text class="board-card__copy">真实发生，拒绝独行。还差 2 位同频好友，解锁本月 60 场深度对话。</text>
    </view>

    <view class="primary-action primary-action--bottom" bindtap="inviteFriend" data-index="{{0}}">发送微信邀请</view>
  </view>
</view>
