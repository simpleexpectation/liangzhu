@import "../access-center/index.wxss";

.invite-friends-page {
  position: relative;
  overflow: hidden;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.invite-friends-page .board-card {
  margin-top: 22rpx;
  border-radius: 34rpx;
  padding: 30rpx 28rpx 34rpx;
  background:
    radial-gradient(circle at 16% 22%, rgba(135, 151, 182, 0.12), transparent 26%),
    radial-gradient(circle at 82% 84%, rgba(240, 219, 149, 0.12), transparent 28%),
    linear-gradient(145deg, rgba(19, 19, 19, 0.96) 0%, rgba(24, 24, 24, 0.94) 48%, rgba(27, 27, 27, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 16rpx 36rpx rgba(0, 0, 0, 0.18);
}

.invite-friends-page .board-card__eyebrow {
  color: rgba(243, 241, 231, 0.54);
  font-size: 20rpx;
  line-height: 1.7;
  letter-spacing: 0.4rpx;
}

.invite-friends-page .board-grid {
  gap: 28rpx;
}

.invite-friends-page .board-node {
  flex: 1;
  gap: 12rpx;
}

.invite-friends-page .board-node__orb {
  width: 122rpx;
  height: 102rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 76% 22%, rgba(146, 168, 190, 0.16), rgba(21, 21, 21, 0) 54%),
    radial-gradient(circle at 24% 78%, rgba(191, 151, 130, 0.12), rgba(21, 21, 21, 0) 58%),
    linear-gradient(145deg, rgba(39, 42, 47, 0.96), rgba(27, 28, 30, 0.94));
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.06),
    0 14rpx 30rpx rgba(0, 0, 0, 0.16);
}

.invite-friends-page .board-node__orb--active {
  background:
    radial-gradient(circle at 78% 22%, rgba(206, 225, 149, 0.22), rgba(20, 20, 20, 0) 52%),
    radial-gradient(circle at 22% 78%, rgba(229, 176, 124, 0.22), rgba(20, 20, 20, 0) 56%),
    linear-gradient(145deg, rgba(148, 166, 181, 0.9), rgba(188, 157, 143, 0.88) 50%, rgba(117, 136, 113, 0.9) 100%);
  box-shadow:
    inset 0 0 0 2rpx rgba(241, 240, 231, 0.2),
    0 0 0 8rpx rgba(173, 186, 168, 0.08),
    0 18rpx 40rpx rgba(0, 0, 0, 0.2);
}

.invite-friends-page .board-node__status {
  color: rgba(243, 241, 231, 0.86);
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 500;
  letter-spacing: 0.4rpx;
}

.invite-friends-page .board-node__label {
  color: rgba(243, 241, 231, 0.48);
  font-size: 20rpx;
  line-height: 1.55;
  letter-spacing: 0.2rpx;
}

.invite-friends-page .board-card__copy {
  margin-top: 26rpx;
  color: rgba(243, 241, 231, 0.74);
  font-size: 24rpx;
  line-height: 1.7;
}
