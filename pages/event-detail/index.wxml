<view class="page-shell event-detail-page {{pageReady ? 'page-ready' : ''}} {{pageLeaving ? 'page-leaving' : ''}}">
  <block wx:if="{{detailMode === 'profile'}}">
    <view class="event-reading" style="padding-top: {{statusBarHeight + 22}}px;">
      <text class="event-reading__eyebrow">THOUGHT</text>
      <view class="event-reading__head">
        <view>
          <text class="event-reading__title">思考详情</text>
          <text class="event-reading__sub">这一条思考，正在怎样慢慢代表一个人</text>
        </view>
      </view>

      <view class="event-reading__hero detail-hero--{{event.heroTone}} {{pageReady ? 'event-reading__hero--ready' : ''}}">
        <view class="detail-hero__mist detail-hero__mist--a"></view>
        <view class="detail-hero__mist detail-hero__mist--b"></view>
        <view class="event-reading__hero-body">
          <view class="event-reading__topline">
            <text class="event-reading__tag">{{event.previewEyebrow || event.kindLabel}}</text>
            <text class="event-reading__date">{{event.date}}</text>
          </view>
          <view class="event-reading__center">
            <text class="event-reading__hero-title">{{event.previewTitle}}</text>
          </view>
          <view class="event-reading__bottomline">
            <text class="event-reading__foot">{{event.graphTag}}</text>
            <text class="event-reading__foot">{{event.venue}}</text>
          </view>
        </view>
      </view>

      <view class="detail-block detail-block--soft {{pageReady ? 'detail-block--ready' : ''}}">
        <text class="detail-block__title">它正在代表什么</text>
        <text class="detail-block__copy">{{event.identityLens}}</text>
      </view>

      <view class="detail-block detail-block--soft {{pageReady ? 'detail-block--ready detail-block--delay-a' : ''}}">
        <text class="detail-block__title">它连接到的内在问题</text>
        <text class="detail-block__copy">{{event.innerQuestion}}</text>
      </view>

      <view class="detail-block detail-block--soft {{pageReady ? 'detail-block--ready detail-block--delay-b' : ''}}">
        <text class="detail-block__title">这一条留下来的原因</text>
        <text class="detail-block__copy">{{event.body}}</text>
      </view>

      <view class="info-grid info-grid--profile {{pageReady ? 'info-grid--ready detail-block--delay-b' : ''}}">
        <view class="info-card">
          <text class="info-card__label">类型</text>
          <text class="info-card__value">{{event.kindLabel}}</text>
        </view>
        <view class="info-card">
          <text class="info-card__label">图谱节点</text>
          <text class="info-card__value">{{event.graphTag}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="detail-hero detail-hero--0 {{pageReady ? 'detail-hero--ready' : ''}}" style="padding-top: {{statusBarHeight + 44}}px;">
      <view class="detail-hero__mist detail-hero__mist--a"></view>
      <view class="detail-hero__mist detail-hero__mist--b"></view>
      <view class="detail-hero__body">
        <view class="pill detail-hero__pill">官方核心局</view>
        <text class="detail-hero__title">{{event.title}}</text>
        <text class="detail-hero__desc">{{event.description}}</text>
      </view>
    </view>

    <view class="meta-list {{pageReady ? 'meta-list--ready' : ''}}">
      <view class="meta-row">
        <text class="meta-row__label">时间</text>
        <text class="meta-row__value">{{event.schedule}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-row__label">地点</text>
        <text class="meta-row__value">{{event.location}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-row__label">引导人</text>
        <text class="meta-row__value">{{event.guide || event.host}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-row__label">席位</text>
        <text class="meta-row__value">{{event.seatsText || event.status}}</text>
      </view>
    </view>

    <view class="detail-block {{pageReady ? 'detail-block--ready detail-block--delay-a' : ''}}">
      <text class="detail-block__title">到场之后</text>
      <text class="detail-block__copy">碰一碰进场，界面退到黑洞模式。你只会看到同场的人、他们的极简名片，以及轻触共鸣入口。</text>
    </view>

    <view class="info-grid {{pageReady ? 'info-grid--ready detail-block--delay-b' : ''}}">
      <view class="info-card">
        <text class="info-card__label">报名权益</text>
        <text class="info-card__value">399 票可参加单领域全部场次</text>
      </view>
      <view class="info-card">
        <text class="info-card__label">核销方式</text>
        <text class="info-card__value">NFC 场地卡 + 二维码兜底</text>
      </view>
    </view>
  </block>
</view>

<view class="detail-footer">
  <view class="detail-footer__rail">
    <view class="detail-footer__back {{pressedFooterAction === 'back' ? 'detail-footer__back--pressed' : ''}}" data-action="back" bindtouchstart="pressFooterAction" bindtouchend="releaseFooterAction" bindtouchcancel="releaseFooterAction" bindtap="goBack">返回</view>
    <block wx:if="{{detailMode === 'profile'}}">
      <view class="detail-footer__cta {{pressedFooterAction === 'primary' ? 'detail-footer__cta--pressed' : ''}}" data-action="primary" bindtouchstart="pressFooterAction" bindtouchend="releaseFooterAction" bindtouchcancel="releaseFooterAction" bindtap="goBack">返回</view>
      <view class="detail-footer__ghost {{pressedFooterAction === 'ghost' ? 'detail-footer__ghost--pressed' : ''}}" data-action="ghost" bindtouchstart="pressFooterAction" bindtouchend="releaseFooterAction" bindtouchcancel="releaseFooterAction" bindtap="pinEventToCard">保存思考</view>
    </block>
    <block wx:else>
      <view class="detail-footer__cta {{pressedFooterAction === 'primary' ? 'detail-footer__cta--pressed' : ''}}" data-action="primary" bindtouchstart="pressFooterAction" bindtouchend="releaseFooterAction" bindtouchcancel="releaseFooterAction" bindtap="openRsvpModal">实名预约</view>
      <view class="detail-footer__ghost {{pressedFooterAction === 'ghost' ? 'detail-footer__ghost--pressed' : ''}}" data-action="ghost" bindtouchstart="pressFooterAction" bindtouchend="releaseFooterAction" bindtouchcancel="releaseFooterAction" bindtap="enterBlackhole">查看现场模式</view>
    </block>
  </view>
</view>

<view wx:if="{{showRsvpModal && detailMode !== 'profile'}}" class="rsvp-mask" bindtap="closeRsvpModal">
  <view class="rsvp-sheet" catchtap="">
    <view class="rsvp-sheet__handle"></view>
    <text class="rsvp-sheet__eyebrow">确认实名预约</text>
    <text class="rsvp-sheet__event">{{event.title}}</text>
    <view wx:if="{{noShowCount >= 2}}" class="rsvp-warning">
      <view class="rsvp-warning__bar"></view>
      <view class="rsvp-warning__body">
        <text class="rsvp-warning__headline">月票资格风险提示</text>
        <text class="rsvp-warning__copy">本月已有 {{noShowCount}} 次预约活动未签到。若本月内超过两次未签到，月票资格将被自动取消。</text>
      </view>
    </view>
    <view class="rsvp-sheet__actions">
      <view class="cta-button cta-button--ghost" bindtap="closeRsvpModal">取消</view>
      <view class="cta-button cta-button--light" bindtap="confirmRsvp">确认预约</view>
    </view>
  </view>
</view>
