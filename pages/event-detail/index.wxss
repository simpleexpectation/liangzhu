.event-detail-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.event-reading__eyebrow {
  display: block;
  margin-bottom: 14rpx;
  font-size: 18rpx;
  color: rgba(243, 241, 231, 0.34);
  letter-spacing: 5rpx;
}

.event-reading__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.event-reading__title {
  display: block;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.04;
  color: rgba(243, 241, 231, 0.94);
}

.event-reading__sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: rgba(243, 241, 231, 0.48);
}

.detail-hero {
  position: relative;
  overflow: hidden;
  margin: 0 -32rpx;
  padding: 0 32rpx 40rpx;
  min-height: 480rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  opacity: 0;
  transform: translateY(28rpx) scale(0.986);
  transition: transform 320ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 320ms ease;
}

.detail-hero--ready,
.event-reading__hero--ready {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.detail-hero--0 {
  background: linear-gradient(180deg, #738087, #c8beb7 76%, #c19a76 100%);
}

.detail-hero--1 {
  background:
    radial-gradient(circle at 80% 14%, rgba(248, 233, 184, 0.26), transparent 26%),
    linear-gradient(145deg, #b7b7cd 0%, #cdbdad 48%, #bcc8a2 100%);
}

.detail-hero--2 {
  background:
    radial-gradient(circle at 80% 16%, rgba(248, 233, 184, 0.24), transparent 24%),
    linear-gradient(145deg, #547468 0%, #7f8f7e 48%, #d1c39f 100%);
}

.detail-hero--3 {
  background:
    radial-gradient(circle at 82% 14%, rgba(245, 234, 190, 0.24), transparent 26%),
    linear-gradient(145deg, #e4ddd2 0%, #c7bdaf 54%, #ede2d2 100%);
}

.detail-hero--4 {
  background:
    radial-gradient(circle at 82% 14%, rgba(245, 230, 182, 0.24), transparent 26%),
    linear-gradient(145deg, #9aa0b2 0%, #938475 52%, #cbb393 100%);
}

.event-reading__hero {
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  min-height: 620rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  opacity: 0;
  transform: translateY(28rpx) scale(0.986);
  transition: transform 320ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 320ms ease;
}

.detail-hero__mist {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  animation: drift 8s ease-in-out infinite;
  pointer-events: none;
}

.detail-hero__mist--a {
  top: -40rpx;
  right: 20rpx;
  width: 320rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.2);
}

.detail-hero__mist--b {
  left: 20rpx;
  bottom: 20rpx;
  width: 300rpx;
  height: 200rpx;
  background: rgba(255, 195, 157, 0.22);
  animation-delay: -2.5s;
}

.detail-hero__body {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 40rpx;
}

.detail-hero__pill {
  background: rgba(255, 255, 255, 0.22);
  color: rgba(255, 255, 255, 0.92);
  align-self: flex-start;
}

.detail-hero__title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.06;
  letter-spacing: -1.5rpx;
  color: #ffffff;
}

.detail-hero__desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.6;
}

.event-reading__hero-body {
  position: relative;
  z-index: 2;
  height: 100%;
  min-height: 564rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.event-reading__topline,
.event-reading__bottomline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.event-reading__tag {
  min-width: 120rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(68, 74, 75, 0.34);
  color: rgba(255, 255, 255, 0.88);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.event-reading__date,
.event-reading__foot {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.event-reading__center {
  max-width: 560rpx;
}

.event-reading__hero-title {
  display: block;
  font-size: 62rpx;
  line-height: 1.14;
  color: #ffffff;
  font-weight: 700;
}

.meta-list {
  margin-top: 36rpx;
  border-radius: 28rpx;
  background: #111214;
  overflow: hidden;
  opacity: 0;
  transform: translateY(22rpx);
  transition: transform 300ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 300ms ease;
}

.meta-list--ready {
  opacity: 1;
  transform: translateY(0);
}

.meta-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 22rpx 26rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-row__label {
  font-size: 22rpx;
  color: rgba(243, 241, 231, 0.45);
  flex-shrink: 0;
  width: 100rpx;
}

.meta-row__value {
  font-size: 26rpx;
  color: rgba(243, 241, 231, 0.9);
  text-align: right;
  flex: 1;
}

.detail-block {
  margin-top: 24rpx;
  border-radius: 28rpx;
  padding: 28rpx;
  background: #111214;
  opacity: 0;
  transform: translateY(22rpx);
  transition: transform 300ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 300ms ease;
}

.detail-block--ready {
  opacity: 1;
  transform: translateY(0);
}

.detail-block--soft {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.detail-block__title {
  display: block;
  font-size: 22rpx;
  color: rgba(243, 241, 231, 0.45);
  letter-spacing: 0.5rpx;
  margin-bottom: 14rpx;
}

.detail-block__copy {
  display: block;
  font-size: 27rpx;
  color: rgba(243, 241, 231, 0.88);
  line-height: 1.7;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
  opacity: 0;
  transform: translateY(22rpx);
  transition: transform 300ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 300ms ease;
}

.info-grid--ready {
  opacity: 1;
  transform: translateY(0);
}

.detail-block--delay-a {
  transition-delay: 60ms;
}

.detail-block--delay-b {
  transition-delay: 120ms;
}

.info-grid--profile {
  margin-top: 24rpx;
}

.info-card {
  border-radius: 28rpx;
  padding: 26rpx 22rpx;
  background: #111214;
}

.info-card__label {
  display: block;
  font-size: 22rpx;
  color: rgba(243, 241, 231, 0.45);
  margin-bottom: 14rpx;
}

.info-card__value {
  display: block;
  font-size: 26rpx;
  color: rgba(243, 241, 231, 0.9);
  line-height: 1.5;
}

.detail-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  z-index: 20;
}

.detail-footer__rail {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 14rpx 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(96, 59, 20, 0.18), rgba(0, 0, 0, 0)),
    #000000;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 -4rpx 40rpx rgba(0, 0, 0, 0.5);
}

.detail-footer__back {
  padding: 0 24rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(243, 241, 231, 0.7);
  font-size: 26rpx;
  flex-shrink: 0;
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, opacity 180ms ease, box-shadow 180ms ease;
}

.detail-footer__cta {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f1eddd, #d8cfb5);
  color: #111111;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow:
    0 10rpx 18rpx rgba(0, 0, 0, 0.12),
    0 0 24rpx rgba(255, 245, 216, 0.12);
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, box-shadow 180ms ease, filter 180ms ease;
}

.detail-footer__ghost {
  padding: 0 22rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: rgba(243, 241, 231, 0.7);
  font-size: 24rpx;
  flex-shrink: 0;
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, opacity 180ms ease, background 180ms ease;
}

.detail-footer__back--pressed,
.detail-footer__ghost--pressed {
  transform: translateY(4rpx) scale(0.97);
  opacity: 0.82;
}

.detail-footer__cta--pressed {
  transform: translateY(4rpx) scale(0.98);
  box-shadow:
    0 6rpx 10rpx rgba(0, 0, 0, 0.1),
    0 0 16rpx rgba(255, 245, 216, 0.08);
  filter: brightness(0.98);
}

.rsvp-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  animation: rsvpFadeIn 0.22s ease;
}

.rsvp-sheet {
  width: 100%;
  background: var(--panel);
  border-top: 1rpx solid var(--line);
  border-radius: 48rpx 48rpx 0 0;
  padding: 20rpx 32rpx 56rpx;
  animation: rsvpSlideUp 0.32s cubic-bezier(0.4, 0, 0.2, 1);
}

.rsvp-sheet__handle {
  width: 72rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--line);
  margin: 0 auto 36rpx;
}

.rsvp-sheet__eyebrow {
  display: block;
  color: var(--text-tertiary);
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.rsvp-sheet__event {
  display: block;
  color: var(--text-primary);
  font-size: 46rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -1rpx;
  margin-bottom: 40rpx;
}

.rsvp-warning {
  display: flex;
  gap: 18rpx;
  background: rgba(215, 166, 161, 0.07);
  border: 1rpx solid rgba(215, 166, 161, 0.18);
  border-radius: 28rpx;
  padding: 26rpx 24rpx;
  margin-bottom: 40rpx;
}

.rsvp-warning__bar {
  flex-shrink: 0;
  width: 4rpx;
  border-radius: 2rpx;
  background: var(--danger);
}

.rsvp-warning__body {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rsvp-warning__headline {
  color: var(--danger);
  font-size: 24rpx;
  font-weight: 600;
}

.rsvp-warning__copy {
  color: rgba(243, 241, 231, 0.82);
  font-size: 24rpx;
  line-height: 1.7;
}

.rsvp-sheet__actions {
  display: flex;
  gap: 18rpx;
}

.rsvp-sheet__actions .cta-button {
  flex: 1;
}

@keyframes rsvpFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes rsvpSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
